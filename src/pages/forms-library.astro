---
import Layout from '../layouts/Layout.astro';

const title = 'Patient Forms | Dr. Alan S. Lee, DDS';
const description = 'Complete your patient forms online before your visit. HIPAA-compliant, encrypted, and secure. New patient registration, medical history, consent forms, and more.';
const canonicalUrl = 'https://dralanlee.com/forms-library/';

// Form definitions - JotForm iframe embed IDs
const newPatientForms = [
  {
    id: '220485359296062',
    title: 'New Patient Registration',
    desc: 'Personal information, contact details, insurance, and demographic data.',
    icon: 'clipboard',
    accent: false,
  },
  {
    id: '220628154987061',
    title: 'Medical & Dental History',
    desc: 'Current medications, allergies, past dental treatments, and health conditions.',
    icon: 'heartbeat',
    accent: false,
  },
];

const policyForms = [
  {
    id: '250671059783060',
    title: 'Appointment Policy',
    desc: 'Our appointment scheduling, cancellation, and late arrival policies.',
    icon: 'calendar',
  },
  {
    id: '250670937244056',
    title: 'Financial Policy',
    desc: 'Payment terms, insurance billing, and financial responsibility details.',
    icon: 'dollar',
  },
];

const consentForms = [
  {
    id: '261347052218149',
    title: 'Consent for Treatment',
    desc: 'Authorize dental examinations, diagnostics, and treatment.',
    icon: 'check',
  },
  {
    id: '261346489311156',
    title: 'Records Release Authorization',
    desc: 'Authorize release of dental records to another office or insurer.',
    icon: 'share',
  },
];
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>
  <!-- Hero -->
  <section class="legal-hero" data-animate>
    <div class="container-wide">
      <div class="section-label">Patient Resources</div>
      <h1 class="section-title">Patient Forms</h1>
      <p class="legal-hero-subtitle">Complete your forms before your visit to save time. All online submissions are HIPAA-encrypted and secure — never leave this site.</p>
    </div>
  </section>

  <!-- HIPAA Trust Bar -->
  <section class="trust-bar" data-animate>
    <div class="container-narrow">
      <div class="trust-inner">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
        <span>Your information is protected by HIPAA-compliant encryption. Forms are submitted directly to our office — no third-party sites. <a href="/hipaa-privacy/">Learn more about your privacy rights →</a></span>
        <span style="display: block; margin-top: 0.5rem; font-size: 0.78rem; color: rgba(100,116,139,0.8);">\u2699\uFE0F <strong>Notice at Collection (CCPA):</strong> We collect personal and health information through these forms to provide dental care. We do not sell your information. <a href="/privacy-policy/" style="color: rgba(100,116,139,0.9);">Privacy Policy</a></span>
      </div>
    </div>
  </section>

  <!-- New Patient Forms -->
  <section class="section-pad">
    <div class="container-narrow" data-animate>
      <h2 class="section-heading">New Patient Registration</h2>
      <p class="section-description">If you're a new patient, please complete these forms before your first visit. Click any form to open it right here on this page.</p>

      <div class="forms-grid">
        {newPatientForms.map((form) => (
          <button class="form-card" data-form-id={form.id} data-form-title={form.title} type="button">
            <div class="form-card-top">
              <div class={`form-icon ${form.accent ? 'accent' : ''}`}>
                {form.icon === 'clipboard' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>}
                {form.icon === 'heartbeat' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>}
                {form.icon === 'shield' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>}
                {form.icon === 'card' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>}
              </div>
              <div>
                <h3>{form.title}</h3>
                <p>{form.desc}</p>
              </div>
            </div>
            <div class="form-card-action">
              <span>Open Form</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Consent & Authorization -->
  <section class="section-pad alt-bg">
    <div class="container-narrow" data-animate>
      <h2 class="section-heading">Consent & Authorization</h2>
      <p class="section-description">Required consent forms for treatment and records.</p>

      <div class="forms-grid three-col">
        {consentForms.map((form) => (
          <button class="form-card" data-form-id={form.id} data-form-title={form.title} type="button">
            <div class="form-card-top">
              <div class="form-icon">
                {form.icon === 'check' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><polyline points="16 13 12 17 10 15"></polyline></svg>}
                {form.icon === 'share' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line></svg>}
              </div>
              <div>
                <h3>{form.title}</h3>
                <p>{form.desc}</p>
              </div>
            </div>
            <div class="form-card-action">
              <span>Open Form</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Office Policies -->
  <section class="section-pad">
    <div class="container-narrow" data-animate>
      <h2 class="section-heading">Office Policies</h2>
      <p class="section-description">Please review our appointment and financial policies before your visit.</p>

      <div class="forms-grid two-col">
        {policyForms.map((form) => (
          <button class="form-card" data-form-id={form.id} data-form-title={form.title} type="button">
            <div class="form-card-top">
              <div class="form-icon">
                {form.icon === 'calendar' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>}
                {form.icon === 'dollar' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"></path><path d="M12 18V6"></path></svg>}
              </div>
              <div>
                <h3>{form.title}</h3>
                <p>{form.desc}</p>
              </div>
            </div>
            <div class="form-card-action">
              <span>Open Form</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>
  <!-- Form Modal -->
  <div id="form-modal" class="form-modal" role="dialog" aria-modal="true" aria-label="Patient form">
    <div class="form-modal-backdrop" id="modal-backdrop"></div>
    <div class="form-modal-content">
      <div class="form-modal-header">
        <h2 id="modal-title">Loading Form...</h2>
        <div class="form-modal-actions">
          <a id="modal-new-tab" href="#" target="_blank" rel="noopener noreferrer" class="btn-sm btn-outline">Open in New Tab</a>
          <button id="modal-close" class="btn-sm btn-close" aria-label="Close form">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
      </div>
      <div class="form-modal-body">
        <div class="jotform-embed" id="jotform-container">
          <div class="form-loading" id="form-loading">
            <div class="loading-spinner"></div>
            <p>Loading secure form...</p>
            <p class="loading-sub">Your data is encrypted and HIPAA-compliant</p>
          </div>
        </div>
      </div>
      <div class="form-modal-footer">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        <span>All forms are HIPAA-encrypted. Your information is submitted directly to Dr. Lee's office.</span>
      </div>
    </div>
  </div>

  <!-- Tips -->
  <section class="section-pad">
    <div class="container-narrow" data-animate>
      <h2 class="section-heading">Before Your Visit</h2>

      <div class="tips-grid">
        <div class="tip-item">
          <div class="tip-number">1</div>
          <div>
            <h4>Complete Online for Fastest Processing</h4>
            <p>Online forms are HIPAA-compliant and submitted directly to our office, saving you time during your visit.</p>
          </div>
        </div>
        <div class="tip-item">
          <div class="tip-number">2</div>
          <div>
            <h4>Bring Required Documentation</h4>
            <p>Please bring a valid photo ID, dental insurance card, list of current medications, and any relevant dental records.</p>
          </div>
        </div>
        <div class="tip-item">
          <div class="tip-number">3</div>
          <div>
            <h4>Arrive 15 Minutes Early</h4>
            <p>This allows time to verify your paperwork. If you completed forms online, we'll confirm the information at check-in.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-pad cta-section" data-animate>
    <div class="container-narrow" style="text-align: center;">
      <h2 class="section-title">Ready to Get Started?</h2>
      <p class="section-subtitle" style="margin: 0 auto 2rem;">Complete your forms and schedule your appointment today.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/schedule-appointment/" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          Schedule Appointment
        </a>
        <a href="tel:+12092392990" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Call (209) 239-2990
        </a>
      </div>
    </div>
  </section>

  <style>
    /* Hero & Trust Bar (same as before) */
    .legal-hero { background: linear-gradient(135deg, var(--primary-950) 0%, var(--primary-800) 100%); color: white; padding: 5rem 1.5rem 4rem; text-align: center; }
    .legal-hero .section-label { color: var(--accent-400); justify-content: center; }
    .legal-hero .section-label::before { background: var(--accent-400); }
    .legal-hero .section-title { color: white; margin-bottom: 1rem; }
    .legal-hero-subtitle { color: rgba(255,255,255,0.85); font-size: 1.1rem; max-width: 600px; margin: 0 auto; line-height: 1.7; font-weight: 300; }
    .trust-bar { background: linear-gradient(135deg, #059669 0%, #047857 100%); padding: 1rem 1.5rem; position: relative; overflow: hidden; }
    .trust-bar::before { content: ''; position: absolute; top: 0; right: 0; width: 200px; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06)); }
    .trust-inner { max-width: 800px; margin: 0 auto; display: flex; align-items: center; gap: 0.75rem; color: white; font-size: 0.9rem; font-weight: 500; position: relative; }
    .trust-inner svg { flex-shrink: 0; }
    .trust-inner a { color: #a7f3d0; text-decoration: underline; font-weight: 600; }
    .trust-inner a:hover { color: white; }

    /* Form Cards */
    .forms-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
    .forms-grid.three-col { grid-template-columns: repeat(3, 1fr); }
    .forms-grid.two-col { grid-template-columns: repeat(2, 1fr); }

    .form-card {
      display: flex; flex-direction: column; justify-content: space-between;
      background: white; border: 1px solid var(--neutral-200); border-radius: var(--radius-lg);
      padding: 1.75rem; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); text-decoration: none; color: inherit;
      cursor: pointer; text-align: left; font-family: inherit; font-size: inherit;
      position: relative; overflow: hidden;
    }
    .form-card::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(2, 132, 199, 0.02) 0%, rgba(7, 89, 133, 0.04) 100%);
      opacity: 0; transition: opacity 0.4s;
    }
    .form-card:hover::before { opacity: 1; }
    .form-card:hover { box-shadow: 0 12px 32px rgba(2, 132, 199, 0.12), 0 4px 8px rgba(0,0,0,0.04); border-color: var(--primary-300); transform: translateY(-4px); }
    .form-card-top { display: flex; gap: 1rem; align-items: flex-start; position: relative; }
    .form-icon { display: flex; align-items: center; justify-content: center; width: 52px; height: 52px; border-radius: var(--radius-md); background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-800) 100%); color: white; flex-shrink: 0; box-shadow: 0 4px 12px rgba(2, 132, 199, 0.25); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
    .form-icon.accent { background: linear-gradient(135deg, var(--accent-500) 0%, var(--accent-600) 100%); box-shadow: 0 4px 12px rgba(245, 158, 11, 0.25); }
    .form-card:hover .form-icon { transform: scale(1.05); box-shadow: 0 6px 18px rgba(2, 132, 199, 0.35); }
    .form-card:hover .form-icon.accent { box-shadow: 0 6px 18px rgba(245, 158, 11, 0.35); }
    .form-card h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--neutral-900); margin-bottom: 0.35rem; transition: color 0.3s; }
    .form-card:hover h3 { color: var(--primary-700); }
    .form-card p { font-size: 0.9rem; color: var(--neutral-500); line-height: 1.55; }
    .form-card-action {
      display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 1.5rem;
      background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-800) 100%);
      color: white; font-weight: 600; font-size: 0.88rem;
      padding: 0.65rem 1.4rem; border-radius: var(--radius-full);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 3px 10px rgba(2, 132, 199, 0.25);
      position: relative;
    }
    .form-card-action svg { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); width: 14px; height: 14px; }
    .form-card:hover .form-card-action {
      box-shadow: 0 6px 20px rgba(2, 132, 199, 0.4);
      transform: translateY(-2px); gap: 0.65rem;
    }
    .form-card:hover .form-card-action svg { transform: translateX(3px); }
    .form-card:active .form-card-action { transform: translateY(0); box-shadow: 0 2px 6px rgba(2, 132, 199, 0.2); }

    /* Modal */
    .form-modal { display: none; position: fixed; inset: 0; z-index: 10000; }
    .form-modal.active { display: flex; align-items: center; justify-content: center; }
    .form-modal-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); }
    .form-modal-content { position: relative; background: white; border-radius: var(--radius-xl); width: 95vw; max-width: 860px; max-height: 90vh; display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 32px 64px rgba(0,0,0,0.25), 0 8px 24px rgba(0,0,0,0.1); animation: fadeInUp 0.35s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .form-modal-header { display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 1.75rem; border-bottom: 1px solid var(--neutral-200); background: linear-gradient(135deg, var(--primary-950) 0%, var(--primary-900) 100%); color: white; }
    .form-modal-header h2 { font-family: var(--font-display); font-size: 1.1rem; color: white; margin: 0; }
    .form-modal-actions { display: flex; gap: 0.5rem; align-items: center; }
    .btn-sm { padding: 0.4rem 0.85rem; font-size: 0.82rem; border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: all var(--transition-fast); }
    .btn-outline { background: transparent; color: rgba(255,255,255,0.8); border: 1px solid rgba(255,255,255,0.3); text-decoration: none; }
    .btn-outline:hover { background: rgba(255,255,255,0.1); color: white; }
    .btn-close { background: transparent; color: rgba(255,255,255,0.7); border: none; padding: 0.3rem; }
    .btn-close:hover { color: white; background: rgba(255,255,255,0.1); border-radius: var(--radius-sm); }
    .form-modal-body { flex: 1; overflow: auto; position: relative; min-height: 600px; }
    .form-modal-body iframe { width: 100%; height: 100%; min-height: 600px; border: none; }
    .form-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3rem; color: var(--neutral-500); }
    .loading-spinner { width: 36px; height: 36px; border: 3px solid var(--neutral-200); border-top-color: var(--primary-600); border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 1rem; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loading-sub { font-size: 0.82rem; color: var(--success); margin-top: 0.25rem; }
    .form-modal-footer { display: flex; align-items: center; gap: 0.5rem; padding: 0.85rem 1.75rem; border-top: 1px solid var(--neutral-200); background: linear-gradient(135deg, #ecfdf5, #d1fae5); color: var(--success); font-size: 0.82rem; font-weight: 500; }
    .form-modal-footer svg { flex-shrink: 0; }

    /* Tips */
    .tips-grid { margin-top: 1.5rem; }
    .tip-item { display: flex; gap: 1.25rem; align-items: flex-start; margin-bottom: 1.5rem; }
    .tip-number { font-family: var(--font-display); font-size: 1.3rem; color: white; flex-shrink: 0; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-800) 100%); border-radius: var(--radius-full); box-shadow: 0 4px 12px rgba(2, 132, 199, 0.25); }
    .tip-item h4 { font-family: var(--font-body); font-weight: 600; font-size: 1rem; color: var(--neutral-800); margin-bottom: 0.25rem; }
    .tip-item p { color: var(--neutral-500); line-height: 1.6; font-size: 0.92rem; }

    /* Responsive */
    @media (max-width: 1024px) { .forms-grid.three-col { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 768px) {
      .forms-grid, .forms-grid.three-col { grid-template-columns: 1fr; }
    .forms-grid.two-col { grid-template-columns: 1fr; }
      .legal-hero { padding: 3.5rem 1rem 3rem; }
      .form-modal-content { width: 100vw; max-width: 100vw; max-height: 100vh; border-radius: 0; }
    }
  </style>

  <script>
    const modal = document.getElementById('form-modal');
    const modalTitle = document.getElementById('modal-title');
    const modalNewTab = document.getElementById('modal-new-tab');
    const modalClose = document.getElementById('modal-close');
    const modalBackdrop = document.getElementById('modal-backdrop');
    const jotformContainer = document.getElementById('jotform-container');
    const formLoading = document.getElementById('form-loading');

    function openForm(formId, formTitle) {
      modalTitle.textContent = formTitle;
      const formUrl = 'https://form.jotform.com/' + formId;
      modalNewTab.href = formUrl;

      // Reset container
      jotformContainer.innerHTML = '';
      const loadingDiv = document.createElement('div');
      loadingDiv.className = 'form-loading';
      loadingDiv.id = 'form-loading';
      loadingDiv.innerHTML = '<div class="loading-spinner"></div><p>Loading secure form...</p><p class="loading-sub">Your data is encrypted and HIPAA-compliant</p>';
      jotformContainer.appendChild(loadingDiv);

      // Create iframe
      const iframe = document.createElement('iframe');
      iframe.src = formUrl;
      iframe.title = formTitle;
      iframe.style.width = '100%';
      iframe.style.height = '100%';
      iframe.style.minHeight = '600px';
      iframe.style.border = 'none';
      iframe.onload = () => {
        const ld = document.getElementById('form-loading');
        if (ld) ld.remove();
      };
      jotformContainer.appendChild(iframe);

      modal.classList.add('active');
      document.body.style.overflow = 'hidden';

      // Focus trap
      modalClose.focus();
    }

    function closeForm() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
      jotformContainer.innerHTML = '';
    }

    // Attach click handlers to all form cards
    document.querySelectorAll('.form-card[data-form-id]').forEach(card => {
      card.addEventListener('click', () => {
        openForm(card.dataset.formId, card.dataset.formTitle);
      });
    });

    modalClose.addEventListener('click', closeForm);
    modalBackdrop.addEventListener('click', closeForm);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('active')) {
        closeForm();
      }
    });
  </script>
</Layout>