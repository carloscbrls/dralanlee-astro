---
import Layout from '../layouts/Layout.astro';

const title = 'Patient Forms Library | Dr. Alan S. Lee, DDS';
const description = 'Download or complete patient forms online before your visit. HIPAA-compliant new patient registration, medical history, consent forms, and more.';
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="legal-hero" data-animate>
    <div class="container-wide">
      <div class="section-label">Prepare for Your Visit</div>
      <h1 class="section-title">Patient Forms Library</h1>
      <p class="legal-hero-subtitle">Save time at your appointment by completing your patient forms in advance. All online forms are HIPAA-compliant and submitted securely.</p>
    </div>
  </section>

  <!-- HIPAA Notice -->
  <section class="section-pad" style="padding-bottom: 0;">
    <div class="container-narrow">
      <div class="hipaa-banner" data-animate>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
        <div>
          <strong>HIPAA-Compliant Submission:</strong> All online forms are processed through JotForm with a Business Associate Agreement (BAA) in place. Your health information is encrypted and protected in accordance with HIPAA regulations. <a href="/hipaa-privacy-notice/" style="color: #065f46; text-decoration: underline;">View our HIPAA Notice</a>.
        </div>
      </div>
    </div>
  </section>

  <!-- New Patient Forms -->
  <section class="section-pad">
    <div class="container-narrow" data-animate>
      <div class="section-label">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg>
        New Patient
      </div>
      <h2 class="legal-heading">New Patient Registration</h2>

      <div class="forms-grid">
        <div class="form-card">
          <div class="form-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          </div>
          <h3>New Patient Registration Form</h3>
          <p>Complete your personal information, contact details, and demographic data before your first visit.</p>
          <div class="form-actions">
            <a href="#" class="btn-primary btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              Complete Online
            </a>
            <a href="#" class="btn-secondary btn-sm" download>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              Download PDF
            </a>
          </div>
        </div>

        <div class="form-card">
          <div class="form-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
          </div>
          <h3>Medical &amp; Dental History</h3>
          <p>Provide your complete medical and dental history, including current medications, allergies, and past treatments.</p>
          <div class="form-actions">
            <a href="#" class="btn-primary btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              Complete Online
            </a>
            <a href="#" class="btn-secondary btn-sm" download>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              Download PDF
            </a>
          </div>
        </div>

        <div class="form-card">
          <div class="form-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3>HIPAA Privacy Consent</h3>
          <p>Acknowledge receipt of our Notice of Privacy Practices and authorize the use and disclosure of your health information.</p>
          <div class="form-actions">
            <a href="#" class="btn-primary btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              Complete Online
            </a>
            <a href="#" class="btn-secondary btn-sm" download>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              Download PDF
            </a>
          </div>
        </div>

        <div class="form-card">
          <div class="form-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          </div>
          <h3>Insurance Verification Form</h3>
          <p>Provide your dental insurance information so we can verify your coverage before your appointment.</p>
          <div class="form-actions">
            <a href="#" class="btn-primary btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              Complete Online
            </a>
            <a href="#" class="btn-secondary btn-sm" download>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              Download PDF
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Consent & Authorization -->
  <section class="section-pad alt-bg">
    <div class="container-narrow" data-animate>
      <div class="section-label">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
        Consent &amp; Authorization
      </div>
      <h2 class="legal-heading">Consent &amp; Authorization Forms</h2>

      <div class="forms-grid">
        <div class="form-card">
          <div class="form-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><polyline points="16 13 12 17 10 15"></polyline></svg>
          </div>
          <h3>Consent for Treatment</h3>
          <p>Authorize Dr. Alan S. Lee, DDS to perform dental examinations, diagnostic procedures, and treatment as recommended.</p>
          <div class="form-actions">
            <a href="#" class="btn-primary btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              Complete Online
            </a>
          </div>
        </div>

        <div class="form-card">
          <div class="form-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line></svg>
          </div>
          <h3>Authorization for Release of Records</h3>
          <p>Authorize the release of your dental records to or from another dental office or insurance company.</p>
          <div class="form-actions">
            <a href="#" class="btn-primary btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              Complete Online
            </a>
          </div>
        </div>

        <div class="form-card">
          <div class="form-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
          </div>
          <h3>Financial Responsibility Agreement</h3>
          <p>Acknowledge financial responsibility for dental services not covered by insurance.</p>
          <div class="form-actions">
            <a href="#" class="btn-primary btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              Complete Online
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tips -->
  <section class="section-pad">
    <div class="container-narrow" data-animate>
      <div class="section-label">Before Your Visit</div>
      <h2 class="legal-heading">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
        Tips for Completing Forms
      </h2>

      <div class="tips-grid">
        <div class="tip-item">
          <div class="tip-number">1</div>
          <div>
            <h4>Complete Online for Fastest Processing</h4>
            <p>Online forms are HIPAA-compliant and submitted directly to our office. This saves time during your visit and ensures your information arrives securely.</p>
          </div>
        </div>
        <div class="tip-item">
          <div class="tip-number">2</div>
          <div>
            <h4>Download PDFs If You Prefer Paper</h4>
            <p>If you prefer to fill out forms by hand, download the PDF versions and bring them to your appointment. Please print clearly and sign where indicated.</p>
          </div>
        </div>
        <div class="tip-item">
          <div class="tip-number">3</div>
          <div>
            <h4>Bring Required Documentation</h4>
            <p>Please bring a valid photo ID, your dental insurance card, a list of current medications, and any relevant dental records from your previous dentist.</p>
          </div>
        </div>
        <div class="tip-item">
          <div class="tip-number">4</div>
          <div>
            <h4>Arrive 15 Minutes Early</h4>
            <p>Arriving early allows time to review and verify your paperwork. If you completed forms online, we will confirm the information at check-in.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-pad cta-section" data-animate>
    <div class="container-narrow" style="text-align: center;">
      <div class="section-label" style="justify-content: center;">Ready to Get Started?</div>
      <h2 class="section-title">Schedule Your Appointment</h2>
      <p class="section-subtitle" style="margin: 0 auto 2rem;">Complete your new patient forms online and schedule your first visit today.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/schedule-appointment/" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          Schedule Appointment
        </a>
        <a href="tel:+12092392990" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Call (209) 239-2990
        </a>
      </div>
    </div>
  </section>

  <style>
    .legal-hero {
      background: linear-gradient(135deg, var(--primary-950) 0%, var(--primary-800) 100%);
      color: white; padding: 5rem 1.5rem 4rem; text-align: center;
    }
    .legal-hero .section-label { color: var(--accent-400); justify-content: center; }
    .legal-hero .section-label::before { background: var(--accent-400); }
    .legal-hero .section-title { color: white; margin-bottom: 1rem; }
    .legal-hero-subtitle { color: rgba(255,255,255,0.8); font-size: 1.15rem; max-width: 680px; margin: 0 auto; line-height: 1.7; }

    .hipaa-banner {
      display: flex; gap: 1rem; align-items: flex-start;
      background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
      border: 1px solid #6ee7b7; border-radius: var(--radius-md);
      padding: 1.25rem 1.5rem; color: #065f46;
    }
    .hipaa-banner svg { color: #059669; flex-shrink: 0; margin-top: 2px; }

    .legal-heading {
      font-family: var(--font-display); font-size: 1.65rem; color: var(--neutral-900);
      margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.75rem; line-height: 1.3;
    }
    .legal-heading svg { color: var(--primary-500); flex-shrink: 0; }

    .alt-bg { background: var(--neutral-50); }

    .forms-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 2rem; }
    .form-card {
      background: white; border: 1px solid var(--neutral-200); border-radius: var(--radius-md);
      padding: 1.75rem; transition: all var(--transition-base);
    }
    .form-card:hover { box-shadow: var(--shadow-lg); border-color: var(--primary-200); transform: translateY(-2px); }
    .form-icon {
      display: flex; align-items: center; justify-content: center;
      width: 52px; height: 52px; border-radius: var(--radius-md);
      background: var(--primary-50); color: var(--primary-600); margin-bottom: 1rem;
    }
    .form-card h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--neutral-900); margin-bottom: 0.5rem; }
    .form-card p { font-size: 0.92rem; color: var(--neutral-600); line-height: 1.7; margin-bottom: 1rem; }
    .form-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

    .btn-sm { padding: 0.55rem 1.25rem; font-size: 0.85rem; }

    .tips-grid { margin-top: 1.5rem; }
    .tip-item {
      display: flex; gap: 1.25rem; align-items: flex-start; margin-bottom: 1.5rem;
    }
    .tip-number {
      font-family: var(--font-display); font-size: 1.75rem; color: var(--primary-500);
      flex-shrink: 0; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;
      background: var(--primary-50); border-radius: var(--radius-full);
    }
    .tip-item h4 { font-family: var(--font-body); font-weight: 600; font-size: 1.05rem; color: var(--neutral-900); margin-bottom: 0.35rem; }
    .tip-item p { color: var(--neutral-600); line-height: 1.7; }

    .cta-section { background: linear-gradient(135deg, var(--primary-50) 0%, white 100%); border-top: 1px solid var(--primary-100); }

    @media (max-width: 768px) {
      .forms-grid { grid-template-columns: 1fr; }
      .legal-hero { padding: 3.5rem 1rem 3rem; }
      .hipaa-banner { flex-direction: column; }
    }
  </style>
</Layout>