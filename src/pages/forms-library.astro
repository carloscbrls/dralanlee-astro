---
import Layout from '../layouts/Layout.astro';

const title = 'Patient Forms Library | Dr. Alan S. Lee, DDS';
const description = 'Download or complete patient forms online before your visit. HIPAA-compliant new patient registration, medical history, consent forms, and more.';
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="legal-hero" data-animate>
    <div class="container-wide">
      <div class="section-label">Patient Resources</div>
      <h1 class="section-title">Patient Forms</h1>
      <p class="legal-hero-subtitle">Complete your forms before your visit to save time. All online submissions are HIPAA-encrypted and secure.</p>
    </div>
  </section>

  <!-- HIPAA Trust Bar -->
  <section class="trust-bar" data-animate>
    <div class="container-narrow">
      <div class="trust-inner">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
        <span>Your information is protected by HIPAA-compliant encryption. <a href="/hipaa-privacy-notice/">Learn more about your privacy rights →</a></span>
      </div>
    </div>
  </section>

  <!-- New Patient Forms -->
  <section class="section-pad">
    <div class="container-narrow" data-animate>
      <h2 class="section-heading">New Patient Registration</h2>
      <p class="section-description">If you're a new patient, please complete these forms before your first visit.</p>

      <div class="forms-grid">
        <a href="https://form.jotform.com/261048079832057" class="form-card" target="_blank" rel="noopener noreferrer">
          <div class="form-card-top">
            <div class="form-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
            </div>
            <div>
              <h3>New Patient Registration</h3>
              <p>Personal information, contact details, and demographic data.</p>
            </div>
          </div>
          <div class="form-card-action">
            <span>Complete Online</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>
        </a>

        <a href="https://form.jotform.com/261048079832057" class="form-card" target="_blank" rel="noopener noreferrer">
          <div class="form-card-top">
            <div class="form-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
            </div>
            <div>
              <h3>Medical &amp; Dental History</h3>
              <p>Current medications, allergies, and past dental treatments.</p>
            </div>
          </div>
          <div class="form-card-action">
            <span>Complete Online</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>
        </a>

        <a href="https://form.jotform.com/261048079832057" class="form-card" target="_blank" rel="noopener noreferrer">
          <div class="form-card-top">
            <div class="form-icon accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
            </div>
            <div>
              <h3>HIPAA Privacy Consent</h3>
              <p>Acknowledge receipt of our Notice of Privacy Practices.</p>
            </div>
          </div>
          <div class="form-card-action">
            <span>Complete Online</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>
        </a>

        <a href="https://form.jotform.com/261048079832057" class="form-card" target="_blank" rel="noopener noreferrer">
          <div class="form-card-top">
            <div class="form-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
            </div>
            <div>
              <h3>Insurance Verification</h3>
              <p>Dental insurance details so we can verify your coverage.</p>
            </div>
          </div>
          <div class="form-card-action">
            <span>Complete Online</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Consent & Authorization -->
  <section class="section-pad alt-bg">
    <div class="container-narrow" data-animate>
      <h2 class="section-heading">Consent &amp; Authorization</h2>
      <p class="section-description">Required consent forms for treatment and records.</p>

      <div class="forms-grid three-col">
        <a href="https://form.jotform.com/261048079832057" class="form-card" target="_blank" rel="noopener noreferrer">
          <div class="form-card-top">
            <div class="form-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><polyline points="16 13 12 17 10 15"></polyline></svg>
            </div>
            <div>
              <h3>Consent for Treatment</h3>
              <p>Authorize dental examinations, diagnostics, and treatment.</p>
            </div>
          </div>
          <div class="form-card-action">
            <span>Complete Online</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>
        </a>

        <a href="https://form.jotform.com/261048079832057" class="form-card" target="_blank" rel="noopener noreferrer">
          <div class="form-card-top">
            <div class="form-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line></svg>
            </div>
            <div>
              <h3>Records Release Authorization</h3>
              <p>Authorize release of dental records to another office or insurer.</p>
            </div>
          </div>
          <div class="form-card-action">
            <span>Complete Online</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>
        </a>

        <a href="https://form.jotform.com/261048079832057" class="form-card" target="_blank" rel="noopener noreferrer">
          <div class="form-card-top">
            <div class="form-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            </div>
            <div>
              <h3>Financial Responsibility</h3>
              <p>Acknowledge financial responsibility for services not covered by insurance.</p>
            </div>
          </div>
          <div class="form-card-action">
            <span>Complete Online</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Tips -->
  <section class="section-pad">
    <div class="container-narrow" data-animate>
      <h2 class="section-heading">Before Your Visit</h2>

      <div class="tips-grid">
        <div class="tip-item">
          <div class="tip-number">1</div>
          <div>
            <h4>Complete Online for Fastest Processing</h4>
            <p>Online forms are HIPAA-compliant and submitted directly to our office, saving you time during your visit.</p>
          </div>
        </div>
        <div class="tip-item">
          <div class="tip-number">2</div>
          <div>
            <h4>Bring Required Documentation</h4>
            <p>Please bring a valid photo ID, dental insurance card, list of current medications, and any relevant dental records.</p>
          </div>
        </div>
        <div class="tip-item">
          <div class="tip-number">3</div>
          <div>
            <h4>Arrive 15 Minutes Early</h4>
            <p>This allows time to verify your paperwork. If you completed forms online, we'll confirm the information at check-in.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-pad cta-section" data-animate>
    <div class="container-narrow" style="text-align: center;">
      <h2 class="section-title">Ready to Get Started?</h2>
      <p class="section-subtitle" style="margin: 0 auto 2rem;">Complete your forms and schedule your appointment today.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/schedule-appointment/" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          Schedule Appointment
        </a>
        <a href="tel:+12092392990" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Call (209) 239-2990
        </a>
      </div>
    </div>
  </section>

  <style>
    .legal-hero {
      background: linear-gradient(135deg, var(--primary-950) 0%, var(--primary-800) 100%);
      color: white; padding: 5rem 1.5rem 4rem; text-align: center;
    }
    .legal-hero .section-label { color: var(--accent-400); justify-content: center; }
    .legal-hero .section-label::before { background: var(--accent-400); }
    .legal-hero .section-title { color: white; margin-bottom: 1rem; }
    .legal-hero-subtitle { color: rgba(255,255,255,0.85); font-size: 1.1rem; max-width: 600px; margin: 0 auto; line-height: 1.7; font-weight: 300; }

    .trust-bar {
      background: linear-gradient(135deg, #059669 0%, #047857 100%);
      padding: 0.9rem 1.5rem;
    }
    .trust-inner {
      max-width: 800px; margin: 0 auto;
      display: flex; align-items: center; gap: 0.75rem;
      color: white; font-size: 0.9rem; font-weight: 500;
    }
    .trust-inner svg { flex-shrink: 0; }
    .trust-inner a { color: #a7f3d0; text-decoration: underline; font-weight: 600; }
    .trust-inner a:hover { color: white; }

    .section-heading {
      font-family: var(--font-display); font-size: 1.75rem; color: var(--neutral-900);
      margin-bottom: 0.5rem;
    }
    .section-description {
      color: var(--neutral-500); font-size: 1.05rem; margin-bottom: 2rem; line-height: 1.6;
    }

    .alt-bg { background: var(--neutral-50); }

    .forms-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
    .forms-grid.three-col { grid-template-columns: repeat(3, 1fr); }

    .form-card {
      display: flex; flex-direction: column; justify-content: space-between;
      background: white; border: 1px solid var(--neutral-200); border-radius: var(--radius-md);
      padding: 1.5rem; transition: all var(--transition-base); text-decoration: none; color: inherit;
    }
    .form-card:hover {
      box-shadow: var(--shadow-lg); border-color: var(--primary-300);
      transform: translateY(-3px);
    }
    .form-card-top { display: flex; gap: 1rem; align-items: flex-start; }
    .form-icon {
      display: flex; align-items: center; justify-content: center;
      width: 48px; height: 48px; border-radius: var(--radius-md);
      background: var(--primary-700); color: white; flex-shrink: 0;
    }
    .form-icon.accent { background: var(--accent-500); }
    .form-card h3 { font-family: var(--font-display); font-size: 1.05rem; color: var(--neutral-900); margin-bottom: 0.3rem; }
    .form-card p { font-size: 0.88rem; color: var(--neutral-500); line-height: 1.5; }
    .form-card-action {
      display: flex; align-items: center; gap: 0.4rem; margin-top: 1.25rem;
      color: var(--primary-700); font-weight: 600; font-size: 0.88rem;
    }
    .form-card:hover .form-card-action { color: var(--primary-500); gap: 0.6rem; }

    .tips-grid { margin-top: 1.5rem; }
    .tip-item { display: flex; gap: 1.25rem; align-items: flex-start; margin-bottom: 1.5rem; }
    .tip-number {
      font-family: var(--font-display); font-size: 1.5rem; color: var(--primary-600);
      flex-shrink: 0; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;
      background: var(--primary-50); border-radius: var(--radius-full); border: 2px solid var(--primary-200);
    }
    .tip-item h4 { font-family: var(--font-body); font-weight: 600; font-size: 1rem; color: var(--neutral-800); margin-bottom: 0.25rem; }
    .tip-item p { color: var(--neutral-500); line-height: 1.6; font-size: 0.92rem; }

    .cta-section { background: var(--neutral-50); }

    @media (max-width: 1024px) {
      .forms-grid.three-col { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      .forms-grid, .forms-grid.three-col { grid-template-columns: 1fr; }
      .legal-hero { padding: 3.5rem 1rem 3rem; }
    }
  </style>
</Layout>