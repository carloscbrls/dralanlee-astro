---
import Layout from '../layouts/Layout.astro';

const title = 'Dr. Alan S. Lee, DDS | Manteca Dentist — General & Cosmetic Dentistry';
const description = 'Trusted Manteca dentist for 30+ years. Dr. Alan S. Lee provides general & cosmetic dentistry, implants, whitening, and more. Call (209) 239-2990.';

const servicesSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "name": "Dr. Alan S. Lee, DDS",
  "url": "https://dralanlee.com",
  "telephone": "+1-209-239-2990",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "715 N Main St",
    "addressLocality": "Manteca",
    "addressRegion": "CA",
    "postalCode": "95336"
  },
  "medicalSpecialty": ["Dentistry", "Cosmetic Dentistry", "Restorative Dentistry"],
  "availableService": [
    { "@type": "MedicalProcedure", "name": "General Dentistry", "description": "Comprehensive exams, cleanings, fillings, and preventive care." },
    { "@type": "MedicalProcedure", "name": "Cosmetic Dentistry", "description": "Teeth whitening, veneers, and bonding." },
    { "@type": "MedicalProcedure", "name": "Restorative Dentistry", "description": "Crowns, bridges, and implants." },
    { "@type": "MedicalProcedure", "name": "Preventive Care", "description": "Sealants, fluoride treatments, and regular checkups." }
  ]
};
---

<Layout title={title} description={description} schema={servicesSchema}>

  <!-- ===== HERO SECTION ===== -->
  <section class="hero" aria-label="Welcome to Dr. Alan S. Lee, DDS">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-content container-wide">
      <div class="hero-text animate-fade-up">
        <span class="hero-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          HIPAA Compliant Practice
        </span>
        <h1>Your Smile Deserves<br /><em>Expert Care</em></h1>
        <p class="hero-desc">For over 30 years, Dr. Alan S. Lee has been the dentist Manteca families trust. Gentle, thorough, and personal — dental care the way it should be.</p>
        <div class="hero-actions">
          <a href="/schedule-appointment/" class="btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            Schedule Appointment
          </a>
          <a href="tel:+12092392990" class="btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            (209) 239-2990
          </a>
        </div>
        <div class="hero-trust">
          <div class="trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <span>30+ Years Experience</span>
          </div>
          <div class="trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            <span>HIPAA Compliant</span>
          </div>
          <div class="trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            <span>Gentle & Professional</span>
          </div>
        </div>
      </div>
      <div class="hero-image animate-fade-up delay-3">
        <img src="/images/dental-office-hero.jpg" alt="Modern, welcoming dental office in Manteca — comfortable and professional care" width="500" height="600" loading="eager" />
        <div class="hero-image-frame" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES SECTION ===== -->
  <section class="services section-pad" aria-label="Our dental services" data-animate>
    <div class="container-wide">
      <div class="section-header" style="text-align: center; margin-bottom: 3rem;">
        <span class="section-label" style="justify-content: center;">Our Services</span>
        <h2 class="section-title">Comprehensive Dental Care</h2>
        <p class="section-subtitle" style="margin: 0.75rem auto 0;">From routine cleanings to advanced cosmetic procedures, Dr. Lee provides the full spectrum of dental care under one roof.</p>
      </div>
      <div class="services-grid">
        <div class="service-card" data-animate>
          <div class="service-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line></svg>
          </div>
          <h3>General Dentistry</h3>
          <p>Comprehensive exams, cleanings, fillings, and preventive care to keep your smile healthy for life.</p>
          <a href="/services/" class="service-link" aria-label="Learn more about general dentistry">Learn more →</a>
        </div>
        <div class="service-card" data-animate>
          <div class="service-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          </div>
          <h3>Cosmetic Dentistry</h3>
          <p>Teeth whitening, veneers, and bonding to enhance the natural beauty of your smile with stunning results.</p>
          <a href="/services/" class="service-link" aria-label="Learn more about cosmetic dentistry">Learn more →</a>
        </div>
        <div class="service-card" data-animate>
          <div class="service-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
          </div>
          <h3>Restorative Dentistry</h3>
          <p>Crowns, bridges, and implants to restore function, comfort, and confidence in your smile.</p>
          <a href="/services/" class="service-link" aria-label="Learn more about restorative dentistry">Learn more →</a>
        </div>
        <div class="service-card" data-animate>
          <div class="service-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3>Preventive Care</h3>
          <p>Sealants, fluoride treatments, and regular checkups designed to prevent problems before they start.</p>
          <a href="/services/" class="service-link" aria-label="Learn more about preventive care">Learn more →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT DR. LEE SECTION ===== -->
  <section class="about section-pad" aria-label="About Dr. Lee" data-animate>
    <div class="container-wide">
      <div class="about-grid">
        <div class="about-image-wrap animate-slide-left">
          <img src="/images/dr-lee-portrait-2026.jpg" alt="Dr. Alan S. Lee, DDS — Manteca's trusted dentist" width="500" height="600" loading="lazy" />
          <div class="about-badge">
            <span class="badge-number">30+</span>
            <span class="badge-text">Years Serving<br/>Manteca</span>
          </div>
        </div>
        <div class="about-text animate-fade-up">
          <span class="section-label">About Dr. Lee</span>
          <h2 class="section-title">A Dentist Who <em>Genuinely</em> Cares</h2>
          <p>Dr. Alan S. Lee has been serving the Manteca community for over three decades, building lasting relationships with families who trust him with their dental care. His approach combines advanced dental techniques with the personal attention you deserve.</p>
          <p>Every patient is treated like family — because in our practice, you are. From your first cleaning to complex restorative work, Dr. Lee takes the time to explain your options and ensure you're comfortable every step of the way.</p>
          <div class="about-features">
            <div class="feature">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <span>Gentle, thorough cleanings</span>
            </div>
            <div class="feature">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <span>Modern technology & techniques</span>
            </div>
            <div class="feature">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <span>Insurance-friendly pricing</span>
            </div>
            <div class="feature">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <span>HIPAA-secure patient data</span>
            </div>
          </div>
          <a href="/about/" class="btn-primary" style="margin-top: 1.5rem;">
            Meet Dr. Lee
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY CHOOSE US ===== -->
  <section class="why section-pad" aria-label="Why choose us" data-animate>
    <div class="container-wide">
      <div class="section-header" style="text-align: center; margin-bottom: 3rem;">
        <span class="section-label" style="justify-content: center;">Why Choose Us</span>
        <h2 class="section-title">Dental Care That Puts <em>You</em> First</h2>
      </div>
      <div class="why-grid">
        <div class="why-card" data-animate>
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <h3>On-Time Appointments</h3>
          <p>We respect your time. Appointments start on schedule, because your schedule matters.</p>
        </div>
        <div class="why-card" data-animate>
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <h3>Welcoming & Comfortable</h3>
          <p>A comfortable environment where every patient feels at ease, from routine visits to complex procedures.</p>
        </div>
        <div class="why-card" data-animate>
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3>HIPAA Secure</h3>
          <p>Your health data is protected with the highest standards of privacy and security compliance.</p>
        </div>
        <div class="why-card" data-animate>
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          </div>
          <h3>Trusted Since 1990s</h3>
          <p>Over three decades of serving Manteca families with consistent, quality dental care.</p>
        </div>
      </div>
    </div>
  </section>

   <!-- ===== SMILE BANNER ===== -->
  <section class="smile-banner" aria-label="Confident smiles start here" data-animate>
    <div class="smile-banner-overlay" aria-hidden="true"></div>
    <div class="container-wide smile-banner-content">
      <h2>Confident Smiles Start Here</h2>
      <p>Whether it's your first visit or your fiftieth, we make every appointment comfortable, clear, and focused on you.</p>
      <a href="/schedule-appointment/" class="btn-primary btn-light">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        Schedule Your Appointment
      </a>
    </div>
  </section>

  <!-- ===== CTA SECTION ===== -->
  <section class="cta-section section-pad" aria-label="Schedule an appointment" data-animate>
    <div class="container-wide">
      <div class="cta-card">
        <div class="cta-text">
          <h2>Ready for a Healthier Smile?</h2>
          <p>New and existing patients welcome. Schedule your appointment today — we can't wait to meet you.</p>
        </div>
        <div class="cta-actions">
          <a href="/schedule-appointment/" class="btn-primary btn-cta-hero">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            Schedule Appointment
          </a>
          <a href="tel:+12092392990" class="btn-secondary btn-cta-hero">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            (209) 239-2990
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MAP SECTION ===== -->
  <section class="map-section section-pad" aria-label="Find our office" data-animate>
    <div class="container-wide">
      <div class="section-header" style="text-align: center; margin-bottom: 2rem;">
        <span class="section-label" style="justify-content: center;">Find Us</span>
        <h2 class="section-title">Visit Our Office</h2>
        <p class="section-subtitle" style="margin: 0.5rem auto 0;">715 N Main St, Manteca, CA 95336</p>
      </div>
      <div class="map-embed">
        <iframe src="https://maps.google.com/maps?q=715+N+Main+St,+Manteca,+CA+95336&output=embed" width="100%" height="400" style="border:0; min-height:400px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Dr. Alan S. Lee office location on Google Maps"></iframe>
      </div>
    </div>
  </section>

  <style>
    /* ===== HERO ===== */
    .hero {
      position: relative; min-height: 85vh; display: flex; align-items: center;
      overflow: hidden; background: var(--primary-950);
    }
    .hero-bg {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, var(--primary-900) 0%, var(--primary-950) 40%, #0a1628 100%);
    }
    .hero-bg::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse at 70% 50%, rgba(14, 165, 233, 0.15) 0%, transparent 60%);
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .hero-content {
      position: relative; z-index: 1; display: grid;
      grid-template-columns: 1fr auto; gap: 3rem; align-items: center;
      padding: 4rem 0;
      max-width: 1280px; margin: 0 auto;
      width: 100%; padding-left: 2rem; padding-right: 2rem;
    }
    .hero-text { max-width: 600px; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.4rem;
      background: rgba(5, 150, 105, 0.15); color: #6ee7b7;
      padding: 0.4rem 1rem; border-radius: var(--radius-full);
      font-size: 0.78rem; font-weight: 600; letter-spacing: 0.03em;
      margin-bottom: 1.5rem; border: 1px solid rgba(110, 231, 183, 0.2);
    }
    .hero h1 {
      font-family: var(--font-display); color: white; font-size: 3.5rem;
      line-height: 1.1; margin-bottom: 1.25rem; font-weight: 400;
    }
    .hero h1 em { font-style: italic; color: var(--primary-300); }
    .hero-desc { color: rgba(255,255,255,0.75); font-size: 1.15rem; line-height: 1.7; margin-bottom: 2rem; font-weight: 300; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
    .hero-actions .btn-primary { background: var(--primary-500); font-size: 1rem; padding: 0.9rem 2rem; }
    .hero-actions .btn-primary:hover { background: var(--primary-400); }
    .hero-actions .btn-secondary { border-color: rgba(255,255,255,0.3); color: white; }
    .hero-actions .btn-secondary:hover { border-color: white; background: rgba(255,255,255,0.1); color: white; }
    .hero-trust { display: flex; gap: 1.5rem; flex-wrap: wrap; }
    .trust-item { display: flex; align-items: center; gap: 0.4rem; color: rgba(255,255,255,0.6); font-size: 0.85rem; }
    .trust-item svg { color: var(--primary-400); }

    .hero-image { position: relative; display: flex; justify-content: flex-end; }
    .hero-image img {
      width: 420px; max-width: 100%; border-radius: var(--radius-lg);
      box-shadow: 0 40px 80px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.1);
      object-fit: cover; aspect-ratio: 4/5;
    }
    .hero-image-frame {
      position: absolute; inset: -12px; border: 2px solid rgba(14, 165, 233, 0.2);
      border-radius: calc(var(--radius-lg) + 12px); pointer-events: none;
    }

    /* ===== SMILE BANNER ===== */
    .smile-banner {
      position: relative;
      min-height: 400px;
      display: flex;
      align-items: center;
      background: url('/images/beautiful-smile.jpg') center/cover no-repeat;
      overflow: hidden;
    }
    .smile-banner-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(7, 89, 133, 0.92) 0%, rgba(12, 74, 110, 0.85) 50%, rgba(7, 89, 133, 0.78) 100%);
    }
    .smile-banner-content {
      position: relative; z-index: 1;
      text-align: center;
