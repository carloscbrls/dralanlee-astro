---
import Layout from '../layouts/Layout.astro';
const title = 'Schedule Appointment | Dr. Alan S. Lee, DDS - Manteca Dentist';
const description = 'Schedule your dental appointment with Dr. Alan S. Lee, DDS in Manteca, CA. Call (209) 239-2990 or use our online scheduling form.';
---

<Layout title={title} description={description}>
  <section class="hero">
    <h1>Schedule an Appointment</h1>
    <p>We look forward to seeing you! Schedule online or call us directly.</p>
  </section>

  <section class="content-section">
    <div class="schedule-grid">
      <div class="schedule-info">
        <h2>How to Schedule</h2>
        <p>You can schedule your appointment by:</p>
        <ul>
          <li><strong>Online:</strong> Fill out the form on this page</li>
          <li><strong>Phone:</strong> Call us at <a href="tel:+12092392990">(209) 239-2990</a></li>
          <li><strong>In Person:</strong> Visit us at 715 N Main St, Manteca, CA 95336</li>
        </ul>

        <h3>Office Hours</h3>
        <table class="hours-table">
          <tr><td>Monday</td><td>8:00 AM – 5:00 PM</td></tr>
          <tr><td>Tuesday</td><td>8:00 AM – 5:00 PM</td></tr>
          <tr><td>Wednesday</td><td>8:00 AM – 5:00 PM</td></tr>
          <tr><td>Thursday</td><td>8:00 AM – 5:00 PM</td></tr>
          <tr><td>Friday</td><td>8:00 AM – 2:00 PM</td></tr>
          <tr><td>Saturday – Sunday</td><td>Closed</td></tr>
        </table>

        <h3>New Patients Welcome</h3>
        <p>We welcome new patients and look forward to providing you with quality dental care. Please arrive 15 minutes early for your first appointment to complete any necessary paperwork.</p>

        <h3>What to Bring</h3>
        <ul>
          <li>Photo ID</li>
          <li>Insurance card(s)</li>
          <li>List of current medications</li>
          <li>Completed patient forms (available on our <a href="/forms-library/">Patient Forms</a> page)</li>
        </ul>
      </div>

      <div class="schedule-form">
        <h2>Request an Appointment</h2>
        <iframe src="https://hipaa.jotform.com/260202986387060" title="Schedule Appointment Form" style="width:100%; height:650px; border:none;" loading="lazy"></iframe>
      </div>
    </div>
  </section>

  <style>
    .schedule-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 2rem; }
    .schedule-info h2 { font-family: var(--font-heading); color: var(--primary); margin-bottom: 1rem; }
    .schedule-info h3 { font-family: var(--font-heading); color: var(--primary); }
    .hours-table { width: 100%; margin-bottom: 1rem; }
    .hours-table td { padding: 0.25rem 0.5rem; }
    .hours-table td:first-child { font-weight: 500; }
    .schedule-form h2 { font-family: var(--font-heading); color: var(--primary); margin-bottom: 1rem; }
    @media (max-width: 768px) { .schedule-grid { grid-template-columns: 1fr; } }
  </style>
</Layout>