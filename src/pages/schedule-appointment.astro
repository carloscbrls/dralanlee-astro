---
import Layout from '../layouts/Layout.astro';

const title = 'Schedule an Appointment | Dr. Alan S. Lee, DDS';
const description = 'Schedule your dental appointment online. HIPAA-compliant form submission. Dr. Alan S. Lee, DDS — Manteca, CA. Call (209) 239-2990 for urgent needs.';

const dentistSchema = {
  "@context": "https://schema.org",
  "@type": "Dentist",
  name: "Dr. Alan S. Lee, DDS",
  url: "https://dralanlee.com/schedule-appointment/",
  telephone: "+1-209-239-2990",
  address: {
    "@type": "PostalAddress",
    streetAddress: "715 N Main St",
    addressLocality: "Manteca",
    addressRegion: "CA",
    postalCode: "95336"
  },
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday"], opens: "08:00", closes: "16:30" }
  ]
};
---

<Layout title={title} description={description} schema={dentistSchema}>
  <!-- Hero -->
  <section class="legal-hero" data-animate>
    <div class="container-wide">
      <div class="section-label">Book Your Visit</div>
      <h1 class="section-title">Schedule an Appointment</h1>
      <p class="legal-hero-subtitle">Ready to take the next step? Schedule your dental appointment online or call us directly. We look forward to seeing you.</p>
    </div>
  </section>

  <!-- Two Column: Form + Info -->
  <section class="section-pad">
    <div class="schedule-grid">
      <!-- Info Column -->
      <div class="info-column" data-animate>
        <div class="info-card">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <h3>Call Us Directly</h3>
          <a href="tel:+12092392990" class="phone-large">(209) 239-2990</a>
          <p>For urgent dental needs, please call us directly.</p>
        </div>

        <div class="info-card">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <h3>Office Hours</h3>
          <div class="hours-grid">
            <div class="hours-row"><span>Monday</span><span>8:00 AM – 4:30 PM</span></div>
            <div class="hours-row"><span>Tuesday</span><span>8:00 AM – 4:30 PM</span></div>
            <div class="hours-row"><span>Wednesday</span><span>8:00 AM – 4:30 PM</span></div>
            <div class="hours-row"><span>Thursday</span><span>8:00 AM – 4:30 PM</span></div>
            <div class="hours-row"><span>Friday</span><span>Closed</span></div>
            <div class="hours-row"><span>Saturday</span><span>Closed</span></div>
            <div class="hours-row"><span>Sunday</span><span>Closed</span></div>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <h3>Our Location</h3>
          <p>715 N Main St<br />Manteca, CA 95336</p>
          <a href="https://maps.google.com/?q=715+N+Main+St+Manteca+CA+95336" target="_blank" rel="noopener noreferrer" class="btn-secondary btn-sm">Get Directions →</a>
        </div>

        <div class="info-card hipaa-card">
          <div class="info-icon shield">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
          </div>
          <h3>HIPAA Secure</h3>
          <p>Your information is encrypted and protected under HIPAA regulations. <a href="/hipaa-privacy/">Privacy Notice</a></p>
        </div>
      </div>

      <!-- Form Column: JotForm Embed -->
      <div class="form-column" data-animate>
        <div class="form-header">
          <h2>Request an Appointment</h2>
          <p>Fill out the form below and our team will contact you to confirm your appointment.</p>
        </div>

        <!-- JotForm HIPAA-Compliant Appointment Request Form -->
        <div class="jotform-embed" id="appointment-form-container">
          <script type="text/javascript" src="https://form.jotform.com/jsform/260202986387060" async></script>
          <noscript>
            <p>Your browser does not support JavaScript. Please <a href="https://form.jotform.com/260202986387060" target="_blank" rel="noopener noreferrer">fill out the appointment request form</a> directly.</p>
          </noscript>
        </div>

        <div class="form-disclaimer">
          <p><small>By submitting this form, you consent to being contacted regarding your appointment. Your information is handled in accordance with our <a href="/hipaa-privacy/">HIPAA Notice of Privacy Practices</a>.</small></p>
          <p><small style="font-size: 0.72rem; color: rgba(100,116,139,0.8);">\u2699\uFE0F <strong>Notice at Collection (CCPA):</strong> We collect your name, email, phone, and appointment preferences to schedule your visit. We do not sell your personal information. See our <a href="/privacy-policy/" style="color: rgba(100,116,139,0.9);">Privacy Policy</a> for your California privacy rights.</small></p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .legal-hero {
      background: linear-gradient(135deg, var(--primary-950) 0%, var(--primary-800) 100%);
      color: white; padding: 5rem 1.5rem 4rem; text-align: center;
    }
    .legal-hero .section-label { color: var(--accent-400); justify-content: center; }
    .legal-hero .section-label::before { background: var(--accent-400); }
    .legal-hero .section-title { color: white; margin-bottom: 1rem; }
    .legal-hero-subtitle { color: rgba(255,255,255,0.8); font-size: 1.15rem; max-width: 680px; margin: 0 auto; line-height: 1.7; }

    .schedule-grid {
      display: grid; grid-template-columns: 380px 1fr; gap: 3rem;
      max-width: 1280px; margin: 0 auto; padding: 0 1.5rem;
    }
    .info-column { display: flex; flex-direction: column; gap: 1.25rem; }
    .info-card {
      background: white; border: 1px solid var(--neutral-200); border-radius: var(--radius-lg);
      padding: 1.75rem; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative; overflow: hidden;
    }
    .info-card::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(2, 132, 199, 0.02) 0%, rgba(7, 89, 133, 0.04) 100%);
      opacity: 0; transition: opacity 0.4s;
    }
    .info-card:hover::before { opacity: 1; }
    .info-card:hover { box-shadow: 0 12px 32px rgba(2, 132, 199, 0.1), 0 4px 8px rgba(0,0,0,0.04); border-color: var(--primary-200); transform: translateY(-3px); }
    .info-icon {
      width: 52px; height: 52px; border-radius: var(--radius-md);
      background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-800) 100%); color: white;
      display: flex; align-items: center; justify-content: center; margin-bottom: 0.75rem;
      box-shadow: 0 4px 12px rgba(2, 132, 199, 0.25); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .info-card:hover .info-icon { transform: scale(1.05); box-shadow: 0 6px 18px rgba(2, 132, 199, 0.35); }
    .info-icon.shield { background: #ecfdf5; color: #059669; }
    .info-card h3 { font-family: var(--font-body); font-weight: 600; font-size: 1rem; color: var(--neutral-900); margin-bottom: 0.5rem; transition: color 0.3s; }
    .info-card:hover h3 { color: var(--primary-700); }
    .info-card p { color: var(--neutral-500); font-size: 0.9rem; line-height: 1.6; }
    .phone-large { font-size: 1.5rem; font-weight: 700; color: var(--primary-700); display: block; margin-bottom: 0.5rem; }
    .phone-large:hover { color: var(--primary-500); }
    .hipaa-card { background: linear-gradient(135deg, #ecfdf5, #d1fae5); border-color: #6ee7b7; }
    .hipaa-card .info-icon { background: linear-gradient(135deg, #059669 0%, #047857 100%); color: white; box-shadow: 0 4px 12px rgba(5, 150, 105, 0.25); }
    .hipaa-card:hover .info-icon { box-shadow: 0 6px 18px rgba(5, 150, 105, 0.35); }

    .hours-grid { width: 100%; }
    .hours-row { display: flex; justify-content: space-between; padding: 0.35rem 0; font-size: 0.88rem; border-bottom: 1px solid var(--neutral-100); }
    .hours-row:last-child { border-bottom: none; }
    .hours-row span:first-child { color: var(--neutral-700); font-weight: 500; }
    .hours-row span:last-child { color: var(--neutral-600); }

    .form-column { min-width: 0; }
    .form-header { margin-bottom: 1.5rem; }
    .form-header h2 { font-family: var(--font-display); font-size: 1.5rem; color: var(--neutral-900); margin-bottom: 0.5rem; }
    .form-header p { color: var(--neutral-500); line-height: 1.6; }

    .jotform-embed {
      min-height: 750px; background: var(--neutral-50);
      border: 1px solid var(--neutral-200); border-radius: var(--radius-lg);
      overflow: visible;
    }

    .form-disclaimer { margin-top: 1rem; text-align: center; }
    .form-disclaimer small { color: var(--neutral-400); font-size: 0.82rem; }
    .form-disclaimer a { color: var(--primary-600); }

    .btn-sm { padding: 0.65rem 1.5rem; font-size: 0.88rem; border-radius: var(--radius-full); font-weight: 600; }

    @media (max-width: 1024px) {
      .schedule-grid { grid-template-columns: 1fr; }
      .info-column { order: 2; }
      .form-column { order: 1; }
    }
    @media (max-width: 768px) {
      .legal-hero { padding: 3.5rem 1rem 3rem; }
      .schedule-grid { padding: 0 1rem; }
      .jotform-embed { min-height: 600px; }
    }
  </style>
</Layout>