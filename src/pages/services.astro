---
import Layout from '../layouts/Layout.astro';

const title = 'Dental Services | Dr. Alan S. Lee, DDS — Manteca Dentist';
const description = 'Comprehensive dental services in Manteca, CA — general, cosmetic, restorative, and preventive dentistry. Trusted for 30+ years. Call (209) 239-2990.';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "name": "Dr. Alan S. Lee, DDS",
  "url": "https://dralanlee.com/services/",
  "description": "Comprehensive dental services including general, cosmetic, restorative, and preventive dentistry in Manteca, CA.",
  "provider": {
    "@type": "Dentist",
    "name": "Dr. Alan S. Lee, DDS",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "715 N Main St",
      "addressLocality": "Manteca",
      "addressRegion": "CA",
      "postalCode": "95336"
    }
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Dental Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "General Dentistry" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Cosmetic Dentistry" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Restorative Dentistry" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Preventive Care" } }
    ]
  }
};
---

<Layout title={title} description={description} schema={serviceSchema}>
  <!-- Hero Banner -->
  <section class="services-hero section-pad" data-animate>
    <div class="container-wide">
      <span class="section-label">Our Services</span>
      <h1 class="section-title">Comprehensive Dental Care<br/>for Your Whole Family</h1>
      <p class="section-subtitle">From routine cleanings to advanced restorative work, Dr. Lee provides personalized care in a comfortable, welcoming environment.</p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="services-grid-section section-pad" data-animate>
    <div class="container-wide">
      <div class="services-grid">
        <!-- General Dentistry -->
        <div class="service-card" data-animate>
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a5 5 0 0 1 5 5v3a5 5 0 0 1-10 0V7a5 5 0 0 1 5-5z"/><path d="M7 10H5a2 2 0 0 0-2 2v1a2 2 0 0 0 2 2h2"/><path d="M17 10h2a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2h-2"/><path d="M12 15v4"/><path d="M8 22h8"/><path d="M8 22v-3"/><path d="M16 22v-3"/></svg>
          </div>
          <h2 class="service-card-title">General Dentistry</h2>
          <p class="service-card-desc">Comprehensive care to maintain your oral health, diagnose issues early, and keep your smile healthy year after year.</p>
          <ul class="service-list" role="list">
            <li>Dental exams &amp; cleanings</li>
            <li>Digital X-rays</li>
            <li>Tooth-colored fillings</li>
            <li>Root canal therapy</li>
            <li>Tooth extractions</li>
            <li>Gum disease treatment</li>
            <li>Oral cancer screenings</li>
          </ul>
          <a href="/schedule-appointment/" class="service-link" aria-label="Schedule a general dentistry appointment">
            Schedule Appointment
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Cosmetic Dentistry -->
        <div class="service-card" data-animate>
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
          </div>
          <h2 class="service-card-title">Cosmetic Dentistry</h2>
          <p class="service-card-desc">Enhance the natural beauty of your smile with treatments designed to boost your confidence and appearance.</p>
          <ul class="service-list" role="list">
            <li>Professional teeth whitening</li>
            <li>Porcelain veneers</li>
            <li>Dental bonding</li>
            <li>Tooth-colored fillings</li>
            <li>Smile makeovers</li>
          </ul>
          <a href="/schedule-appointment/" class="service-link" aria-label="Schedule a cosmetic dentistry consultation">
            Schedule Consultation
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Restorative Dentistry -->
        <div class="service-card" data-animate>
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.37 7.37l-6.83 6.83a2 2 0 0 1-2.83-2.83l6.83-6.83a6 6 0 0 1 7.37-7.37z"/></svg>
          </div>
          <h2 class="service-card-title">Restorative Dentistry</h2>
          <p class="service-card-desc">Restore full function and aesthetics to damaged or missing teeth with advanced restorative solutions.</p>
          <ul class="service-list" role="list">
            <li>Dental crowns</li>
            <li>Dental bridges</li>
            <li>Full &amp; partial dentures</li>
            <li>Dental implants</li>
            <li>Inlays &amp; onlays</li>
          </ul>
          <a href="/schedule-appointment/" class="service-link" aria-label="Schedule a restorative dentistry appointment">
            Schedule Appointment
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Preventive Care -->
        <div class="service-card" data-animate>
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <h2 class="service-card-title">Preventive Care</h2>
          <p class="service-card-desc">Stay ahead of dental problems with proactive care designed to protect your oral health for the long term.</p>
          <ul class="service-list" role="list">
            <li>Regular checkups &amp; cleanings</li>
            <li>Dental sealants</li>
            <li>Fluoride treatments</li>
            <li>Oral hygiene education</li>
            <li>Night guards &amp; athletic mouth guards</li>
          </ul>
          <a href="/schedule-appointment/" class="service-link" aria-label="Schedule a preventive care appointment">
            Schedule Checkup
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Additional Services -->
  <section class="additional-services section-pad" data-animate style="background: var(--neutral-50);">
    <div class="container-wide">
      <span class="section-label">Specialized Care</span>
      <h2 class="section-title">Additional Services</h2>
      <div class="additional-grid">
        <div class="additional-item" data-animate>
          <div class="additional-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
          </div>
          <h3>Emergency Dental Care</h3>
          <p>Same-day appointments for toothaches, broken teeth, lost fillings, and dental abscesses.</p>
        </div>
        <div class="additional-item" data-animate>
          <div class="additional-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12h6"/><path d="M12 9v6"/><circle cx="12" cy="12" r="10"/></svg>
          </div>
          <h3>Oral Cancer Screening</h3>
          <p>Thorough screenings during every exam to detect early signs of oral cancer and ensure your health.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="services-cta section-pad" data-animate>
    <div class="container-wide cta-inner">
      <h2 class="section-title" style="color: white;">Ready to Get Started?</h2>
      <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem; margin-bottom: 2rem; max-width: 500px;">Whether you need a routine checkup or have a specific concern, we're here to help you achieve your healthiest smile.</p>
      <div class="cta-buttons">
        <a href="/schedule-appointment/" class="btn-primary" style="background: var(--accent-500); color: var(--neutral-900);">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Schedule Appointment
        </a>
        <a href="tel:+12092392990" class="btn-secondary" style="border-color: rgba(255,255,255,0.3); color: white;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call (209) 239-2990
        </a>
      </div>
    </div>
  </section>

  <style>
    .services-hero {
      background: linear-gradient(135deg, var(--primary-50) 0%, white 100%);
      text-align: center;
      padding-bottom: 3rem;
    }
    .services-hero .section-subtitle { margin: 0 auto; }

    /* Service Cards Grid */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
    .service-card {
      background: white;
      border: 1px solid var(--neutral-200);
      border-radius: var(--radius-lg);
      padding: 2.5rem;
      transition: all var(--transition-base);
      position: relative;
      overflow: hidden;
    }
    .service-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--primary-500), var(--accent-500));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform var(--transition-base);
    }
    .service-card:hover {
      border-color: var(--primary-200);
      box-shadow: var(--shadow-xl);
      transform: translateY(-4px);
    }
    .service-card:hover::before { transform: scaleX(1); }

    .service-icon {
      width: 56px; height: 56px;
      display: flex; align-items: center; justify-content: center;
      background: var(--primary-50);
      color: var(--primary-600);
      border-radius: var(--radius-md);
      margin-bottom: 1.5rem;
    }
    .service-card-title {
      font-family: var(--font-display);
      font-size: 1.5rem;
      color: var(--neutral-900);
      margin-bottom: 0.75rem;
    }
    .service-card-desc {
      color: var(--neutral-500);
      font-size: 0.95rem;
      line-height: 1.7;
      margin-bottom: 1.25rem;
    }
    .service-list {
      list-style: none;
      padding: 0;
      margin-bottom: 1.5rem;
    }
    .service-list li {
      padding: 0.4rem 0;
      color: var(--neutral-600);
      font-size: 0.9rem;
      position: relative;
      padding-left: 1.5rem;
    }
    .service-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.75rem;
      width: 6px; height: 6px;
      background: var(--primary-400);
      border-radius: 50%;
    }
    .service-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--primary-600);
      font-weight: 600;
      font-size: 0.9rem;
      transition: all var(--transition-fast);
    }
    .service-link:hover { color: var(--primary-800); gap: 0.6rem; }

    /* Additional Services */
    .additional-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .additional-item {
      background: white;
      padding: 2rem;
      border-radius: var(--radius-md);
      border: 1px solid var(--neutral-200);
      transition: all var(--transition-base);
    }
    .additional-item:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }
    .additional-icon {
      width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      background: var(--primary-50);
      color: var(--primary-600);
      border-radius: var(--radius-sm);
      margin-bottom: 1rem;
    }
    .additional-item h3 {
      font-family: var(--font-display);
      font-size: 1.15rem;
      margin-bottom: 0.5rem;
      color: var(--neutral-900);
    }
    .additional-item p {
      color: var(--neutral-500);
      font-size: 0.9rem;
      line-height: 1.6;
    }

    /* CTA Section */
    .services-cta {
      background: linear-gradient(135deg, var(--primary-900) 0%, var(--primary-950) 100%);
      text-align: center;
    }
    .cta-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .cta-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .services-grid { grid-template-columns: 1fr; }
      .additional-grid { grid-template-columns: 1fr; }
      .service-card { padding: 2rem; }
    }
    @media (max-width: 480px) {
      .cta-buttons { flex-direction: column; align-items: center; }
      .cta-buttons a { width: 100%; justify-content: center; }
    }

    /* Scroll Animation */
    [data-animate] {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    [data-animate].visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</Layout>