---
import Layout from '../layouts/Layout.astro';

const title = 'Contact Us | Dr. Alan S. Lee, DDS — Manteca Dentist';
const description = 'Contact Dr. Alan S. Lee, DDS in Manteca, CA. Call (209) 239-2990 or visit us at 715 N Main St. HIPAA-compliant communication.';

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Dr. Alan S. Lee, DDS",
  "url": "https://dralanlee.com/contact-the-office/",
  "mainEntity": {
    "@type": "Dentist",
    "name": "Dr. Alan S. Lee, DDS",
    "telephone": "+1-209-239-2990",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "715 N Main St",
      "addressLocality": "Manteca",
      "addressRegion": "CA",
      "postalCode": "95336",
      "addressCountry": "US"
    }
  }
};
---

<Layout title={title} description={description} schema={contactSchema}>
  <!-- Hero -->
  <section class="contact-hero section-pad" data-animate>
    <div class="container-wide">
      <span class="section-label">Contact Us</span>
      <h1 class="section-title">We'd Love to<br/>Hear From You</h1>
      <p class="section-subtitle">Whether you're ready to schedule an appointment or just have a question, our team is here to help.</p>
    </div>
  </section>

  <!-- Contact Grid -->
  <section class="contact-main section-pad" data-animate>
    <div class="container-wide contact-grid">
      <!-- Contact Info -->
      <div class="contact-info" data-animate>
        <div class="info-card">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <h3>Phone</h3>
            <a href="tel:+12092392990" class="info-value">(209) 239-2990</a>
            <p class="info-detail">Call us anytime during business hours</p>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <h3>Address</h3>
            <p class="info-value">715 N Main St<br/>Manteca, CA 95336</p>
            <a href="https://maps.google.com/?q=715+N+Main+St+Manteca+CA+95336" target="_blank" rel="noopener noreferrer" class="info-link">Get Directions →</a>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <h3>Office Hours</h3>
            <table class="hours-table" aria-label="Office hours">
              <tbody>
                <tr><td>Monday</td><td>8:00 AM – 5:00 PM</td></tr>
                <tr><td>Tuesday</td><td>8:00 AM – 5:00 PM</td></tr>
                <tr><td>Wednesday</td><td>8:00 AM – 5:00 PM</td></tr>
                <tr><td>Thursday</td><td>8:00 AM – 5:00 PM</td></tr>
                <tr><td>Friday</td><td>8:00 AM – 2:00 PM</td></tr>
                <tr><td>Sat – Sun</td><td>Closed</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="hipaa-notice" data-animate>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <p><strong>HIPAA Compliant:</strong> All communications are protected under our <a href="/hipaa-privacy-notice/">HIPAA Privacy Notice</a>. Your health information is always kept confidential and secure.</p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form-wrap" data-animate>
        <div class="form-header">
          <h2>Send Us a Message</h2>
          <p>Fill out the form below and we'll get back to you as soon as possible.</p>
        </div>
        <iframe
          src="https://hipaa.jotform.com/260202986387060"
          title="Contact Form — HIPAA Compliant"
          style="width:100%; height:600px; border:none; border-radius: var(--radius-md);"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="map-section" data-animate>
    <div class="container-wide">
      <span class="section-label">Find Us</span>
      <h2 class="section-title" style="font-size: 1.75rem;">Our Location</h2>
    </div>
    <div class="map-container">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3135.5!2d-121.2167!3d37.7975!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x809046e4e4e4e4e%3A0xe4e4e4e4e4e4e4e!2s715+N+Main+St%2C+Manteca%2C+CA+95336!5e0!3m2!1sen!2sus!4v1234567890"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Dr. Alan S. Lee, DDS office location — 715 N Main St, Manteca, CA 95336"
      ></iframe>
    </div>
  </section>

  <!-- CTA -->
  <section class="contact-cta section-pad" data-animate>
    <div class="container-wide cta-inner">
      <h2 class="section-title" style="color: white;">Ready to Schedule?</h2>
      <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem; margin-bottom: 2rem; max-width: 500px;">The fastest way to get started is to call us directly. Our team is ready to help.</p>
      <div class="cta-buttons">
        <a href="/schedule-appointment/" class="btn-primary" style="background: var(--accent-500); color: var(--neutral-900);">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Schedule Online
        </a>
        <a href="tel:+12092392990" class="btn-secondary" style="border-color: rgba(255,255,255,0.3); color: white;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call (209) 239-2990
        </a>
      </div>
    </div>
  </section>

  <style>
    .contact-hero {
      background: linear-gradient(135deg, var(--primary-50) 0%, white 100%);
      text-align: center;
    }
    .contact-hero .section-subtitle { margin: 0 auto; }

    /* Contact Grid */
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      gap: 3rem;
      align-items: start;
    }
    .info-card {
      display: flex;
      gap: 1rem;
      padding: 1.25rem;
      border-radius: var(--radius-md);
      border: 1px solid var(--neutral-200);
      margin-bottom: 1rem;
      transition: all var(--transition-fast);
    }
    .info-card:hover {
      border-color: var(--primary-200);
      box-shadow: var(--shadow-sm);
    }
    .info-icon {
      width: 48px; height: 48px;
      display: flex; align-items: center; justify-content: center;
      background: var(--primary-50);
      color: var(--primary-600);
      border-radius: var(--radius-sm);
      flex-shrink: 0;
    }
    .info-card h3 {
      font-family: var(--font-display);
      font-size: 1.05rem;
      color: var(--neutral-900);
      margin-bottom: 0.25rem;
    }
    .info-value {
      color: var(--neutral-800);
      font-weight: 600;
      font-size: 0.95rem;
      line-height: 1.5;
      text-decoration: none;
    }
    a.info-value { color: var(--primary-700); }
    a.info-value:hover { color: var(--primary-500); }
    .info-detail {
      color: var(--neutral-500);
      font-size: 0.82rem;
      margin-top: 0.15rem;
    }
    .info-link {
      color: var(--primary-600);
      font-size: 0.88rem;
      font-weight: 600;
    }
    .info-link:hover { color: var(--primary-800); }

    .hours-table {
      margin-top: 0.5rem;
      font-size: 0.88rem;
    }
    .hours-table td {
      padding: 0.25rem 0.75rem 0.25rem 0;
      color: var(--neutral-600);
    }
    .hours-table td:first-child {
      font-weight: 600;
      color: var(--neutral-700);
      min-width: 7rem;
    }

    /* HIPAA Notice */
    .hipaa-notice {
      display: flex;
      gap: 0.75rem;
      padding: 1rem 1.25rem;
      background: var(--primary-50);
      border: 1px solid var(--primary-200);
      border-radius: var(--radius-sm);
      margin-top: 0.5rem;
    }
    .hipaa-notice svg { color: var(--success); flex-shrink: 0; margin-top: 0.15rem; }
    .hipaa-notice p { font-size: 0.82rem; color: var(--neutral-600); line-height: 1.5; }
    .hipaa-notice a { color: var(--primary-700); font-weight: 600; }
    .hipaa-notice a:hover { color: var(--primary-500); }

    /* Form */
    .contact-form-wrap {
      background: white;
      border: 1px solid var(--neutral-200);
      border-radius: var(--radius-lg);
      padding: 2rem;
    }
    .form-header h2 {
      font-family: var(--font-display);
      font-size: 1.5rem;
      color: var(--neutral-900);
      margin-bottom: 0.25rem;
    }
    .form-header p {
      color: var(--neutral-500);
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }

    /* Map */
    .map-section { padding-bottom: 3rem; }
    .map-container {
      max-width: 1280px;
      margin: 1.5rem auto 0;
      padding: 0 1.5rem;
    }
    .map-container iframe {
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
    }

    /* CTA */
    .contact-cta {
      background: linear-gradient(135deg, var(--primary-900) 0%, var(--primary-950) 100%);
      text-align: center;
    }
    .cta-inner { display: flex; flex-direction: column; align-items: center; }
    .cta-buttons { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }

    @media (max-width: 768px) {
      .contact-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .cta-buttons { flex-direction: column; align-items: center; }
      .cta-buttons a { width: 100%; justify-content: center; }
    }

    [data-animate] {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    [data-animate].visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</Layout>