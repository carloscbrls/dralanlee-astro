---
import Layout from '../layouts/Layout.astro';

const title = 'Our Team | Dr. Alan S. Lee, DDS — Manteca Dentist';
const description = 'Meet the caring dental team at Dr. Alan S. Lee, DDS in Manteca, CA. Experienced, gentle professionals dedicated to your comfort and dental health.';
const canonicalUrl = 'https://dralanlee.com/staff/';

const teamSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "Our Team — Dr. Alan S. Lee, DDS",
  "description": "Meet the caring dental team at Dr. Alan S. Lee, DDS in Manteca, CA.",
  "url": "https://dralanlee.com/staff/"
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schema={teamSchema}>
  <!-- Hero -->
  <section class="legal-hero" data-animate>
    <div class="container-wide">
      <div class="section-label">Our Team</div>
      <h1 class="section-title">Meet the People<br/>Who Care for Your Smile</h1>
      <p class="legal-hero-subtitle">Our team is dedicated to making every visit comfortable, thorough, and personal. You'll feel the difference from the moment you walk in.</p>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="trust-bar" data-animate>
    <div class="container-narrow">
      <div class="trust-inner">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
        <span>Our team is dedicated to making every visit comfortable, thorough, and personal. You'll feel the difference from the moment you walk in.</span>
      </div>
    </div>
  </section>

  <!-- Dr. Lee Featured -->
  <section class="featured-doctor section-pad" data-animate>
    <div class="container-wide featured-grid">
      <div class="featured-photo-wrap" data-animate>
        <img
          src="/images/dr-lee-portrait-2026-new.jpg"
          alt="Dr. Alan S. Lee, DDS — Lead Dentist and Owner with over 30 years of experience in Manteca"
          class="featured-photo"
          loading="eager"
        />
      </div>
      <div class="featured-info" data-animate>
        <div class="section-label">Lead Dentist</div>
        <h2 class="section-heading">Dr. Alan S. Lee, DDS</h2>
        <p class="featured-role">Owner &amp; Lead Dentist</p>
        <p>Dr. Lee has been serving the Manteca community for over 30 years, providing comprehensive general and cosmetic dental care. After earning his Doctor of Dental Surgery degree, he built his practice on a simple philosophy: treat every patient like family.</p>
        <p>Known for his gentle approach and commitment to continuing education, Dr. Lee stays current with the latest advances in dental science and technology. He takes pride in building lasting relationships with his patients — many of whom have been coming to his office for decades.</p>
        <p>When he's not in the office, Dr. Lee enjoys spending time with his family and being an active part of the Manteca community.</p>
        <div class="featured-highlights">
          <div class="highlight-pill">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            30+ Years Experience
          </div>
          <div class="highlight-pill">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            Gentle Approach
          </div>
          <div class="highlight-pill">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            Patient-Focused Care
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hygienists -->
  <section class="team-grid-section section-pad" data-animate style="background: var(--neutral-50);">
    <div class="container-wide">
      <div class="section-label">Hygienists</div>
      <h2 class="section-heading">Our Dental Hygienists</h2>
      <div class="team-grid">

        <div class="team-card" data-animate>
          <div class="team-card-photo">
            <div class="team-card-placeholder" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
          </div>
          <div class="team-card-body">
            <h3>Rodina</h3>
            <p class="team-role">Registered Dental Hygienist</p>
            <p>Rodina provides thorough, gentle cleanings and personalized oral health education. She takes the time to ensure every patient feels comfortable and well-informed about their dental care.</p>
          </div>
        </div>

        <div class="team-card" data-animate>
          <div class="team-card-photo">
            <img
              src="/images/staff-marinn-hygienist.jpg"
              alt="Marinn, Registered Dental Hygienist at Dr. Alan S. Lee's office"
              loading="lazy"
            />
          </div>
          <div class="team-card-body">
            <h3>Marinn</h3>
            <p class="team-role">Registered Dental Hygienist</p>
            <p>Marinn brings warmth and precision to every cleaning. She's passionate about patient education and making sure you leave with a healthy, confident smile.</p>
          </div>
        </div>

        <div class="team-card" data-animate>
          <div class="team-card-photo">
            <img
              src="/images/staff-kerry-hygienist.jpg"
              alt="Kerry, Registered Dental Hygienist at Dr. Alan S. Lee's office"
              loading="lazy"
            />
          </div>
          <div class="team-card-body">
            <h3>Kerry</h3>
            <p class="team-role">Registered Dental Hygienist</p>
            <p>Kerry is dedicated to providing gentle, comprehensive cleanings. Her attention to detail and caring approach help patients feel at ease during every visit.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Assistants -->
  <section class="team-grid-section section-pad" data-animate>
    <div class="container-wide">
      <div class="section-label">Assistants</div>
      <h2 class="section-heading">Our Dental Assistants</h2>
      <div class="team-grid team-grid--2col">

        <div class="team-card" data-animate>
          <div class="team-card-photo">
            <img
              src="/images/staff-samantha-assistant.jpg"
              alt="Samantha, Certified Dental Assistant at Dr. Alan S. Lee's office"
              loading="lazy"
            />
          </div>
          <div class="team-card-body">
            <h3>Samantha</h3>
            <p class="team-role">Certified Dental Assistant</p>
            <p>Samantha works closely with Dr. Lee during procedures, ensuring everything runs smoothly and efficiently. Her warm, reassuring manner helps make every appointment comfortable.</p>
          </div>
        </div>

        <div class="team-card" data-animate>
          <div class="team-card-photo">
            <img
              src="/images/staff-jazzmine-assistant.jpg"
              alt="Jazzmine, Certified Dental Assistant at Dr. Alan S. Lee's office"
              loading="lazy"
            />
          </div>
          <div class="team-card-body">
            <h3>Jazzmine</h3>
            <p class="team-role">Certified Dental Assistant</p>
            <p>Jazzmine assists Dr. Lee with precision and care, making sure every procedure goes smoothly. Her friendly personality puts patients at ease from the moment they sit in the chair.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Office Team -->
  <section class="team-grid-section section-pad" data-animate style="background: var(--neutral-50);">
    <div class="container-wide">
      <div class="section-label">Office Team</div>
      <h2 class="section-heading">Behind the Front Desk</h2>
      <div class="team-grid team-grid--2col">

        <div class="team-card" data-animate>
          <div class="team-card-photo">
            <img
              src="/images/staff-angelina-office-manager.jpg"
              alt="Angelina, Office Manager at Dr. Alan S. Lee's office"
              loading="lazy"
            />
          </div>
          <div class="team-card-body">
            <h3>Angelina</h3>
            <p class="team-role">Office Manager</p>
            <p>Angelina keeps the entire office running smoothly. From scheduling and insurance verification to patient communications, she's the welcoming voice on the phone and the first smile you see when you visit.</p>
          </div>
        </div>

        <div class="team-card" data-animate>
          <div class="team-card-photo">
            <img
              src="/images/staff-alicia-coordinator.jpg"
              alt="Alicia, Patient Coordinator at Dr. Alan S. Lee's office"
              loading="lazy"
            />
          </div>
          <div class="team-card-body">
            <h3>Alicia</h3>
            <p class="team-role">Patient Coordinator</p>
            <p>Alicia handles scheduling, insurance questions, and billing with efficiency and a smile. She makes sure every aspect of your visit — from check-in to follow-up — is seamless and stress-free.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Why Our Team -->
  <section class="why-team section-pad" data-animate>
    <div class="container-wide">
      <div class="why-grid">
        <div class="why-text">
          <div class="section-label">Why Choose Us</div>
          <h2 class="section-heading">A Team That Truly Cares</h2>
          <p style="color: var(--neutral-500); line-height: 1.8;">Every member of our team was chosen for their skill, compassion, and commitment to patient care. From your first phone call to your follow-up visit, we work together to make sure you feel heard, respected, and well cared for.</p>
          <ul class="why-list" role="list">
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Gentle, patient-centered approach
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Clear communication every step
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Comfortable, welcoming environment
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Insurance &amp; payment assistance
            </li>
          </ul>
        </div>
        <div class="why-cta-card">
          <h3 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 0.75rem; color: var(--neutral-900);">Ready to Meet Us?</h3>
          <p style="color: var(--neutral-500); margin-bottom: 1.5rem; line-height: 1.7;">Schedule your first visit and experience the difference a caring team makes.</p>
          <a href="/schedule-appointment/" class="btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Schedule Appointment
          </a>
          <a href="tel:+12092392990" class="btn-secondary" style="margin-top: 0.75rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call (209) 239-2990
          </a>
        </div>
      </div>
    </div>
  </section>

  <style>

    .legal-hero { background: linear-gradient(135deg, var(--primary-950) 0%, var(--primary-800) 100%); color: white; padding: 5rem 1.5rem 4rem; text-align: center; }
    .legal-hero .section-label { color: var(--accent-400); justify-content: center; }
    .legal-hero .section-label::before { background: var(--accent-400); }
    .legal-hero .section-title { color: white; margin-bottom: 1rem; }
    .legal-hero-subtitle { color: rgba(255,255,255,0.85); font-size: 1.1rem; max-width: 680px; margin: 0 auto; line-height: 1.7; font-weight: 300; }
    .trust-bar { background: linear-gradient(135deg, #059669 0%, #047857 100%); padding: 1rem 1.5rem; position: relative; overflow: hidden; }
    .trust-bar::before { content: ''; position: absolute; top: 0; right: 0; width: 200px; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06)); }
    .trust-inner { max-width: 800px; margin: 0 auto; display: flex; align-items: center; gap: 0.75rem; color: white; font-size: 0.9rem; font-weight: 500; position: relative; }
    .trust-inner svg { flex-shrink: 0; }
    /* Featured Doctor */
    .featured-grid {
      display: grid;
      grid-template-columns: 1fr 1.3fr;
      gap: 4rem;
      align-items: center;
    }
    .featured-photo {
      width: 100%;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-xl);
      aspect-ratio: 4/5;
      object-fit: cover;
    }
    .featured-role {
      color: var(--primary-600);
      font-weight: 600;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 1rem;
    }
    .featured-info p {
      color: var(--neutral-600);
      line-height: 1.8;
      margin-bottom: 0.75rem;
    }
    .featured-highlights {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
    }
    .highlight-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 1rem;
      background: linear-gradient(135deg, rgba(2, 132, 199, 0.08) 0%, rgba(7, 89, 133, 0.12) 100%);
      color: var(--primary-700);
      border: 1px solid rgba(2, 132, 199, 0.15);
      border-radius: var(--radius-full);
      font-size: 0.82rem;
      font-weight: 600;
      transition: all 0.3s ease;
    }
    .highlight-pill:hover {
      background: linear-gradient(135deg, rgba(2, 132, 199, 0.14) 0%, rgba(7, 89, 133, 0.2) 100%);
      border-color: rgba(2, 132, 199, 0.3);
      transform: translateY(-1px);
    }
    .highlight-pill svg { color: var(--primary-500); }

    /* Team Grid */
    .team-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .team-grid--2col {
      grid-template-columns: repeat(2, 1fr);
    }
    .team-card {
      background: white;
      border-radius: var(--radius-lg);
      border: 1px solid var(--neutral-200);
      overflow: hidden;
      transition: all var(--transition-base);
    }
    .team-card:hover {
      box-shadow: var(--shadow-lg);
      transform: translateY(-4px);
    }
    .team-card-photo {
      aspect-ratio: 4/3;
      overflow: hidden;
    }
    .team-card-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--transition-base);
    }
    .team-card:hover .team-card-photo img { transform: scale(1.05); }
    .team-card-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--primary-100) 0%, var(--primary-200) 100%);
      color: var(--primary-600);
    }
    .team-card-body {
      padding: 1.5rem;
    }
    .team-card-body h3 {
      font-family: var(--font-display);
      font-size: 1.2rem;
      color: var(--neutral-900);
      margin-bottom: 0.25rem;
    }
    .team-role {
      color: var(--primary-600);
      font-size: 0.82rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.75rem;
    }
    .team-card-body p:last-child {
      color: var(--neutral-500);
      font-size: 0.9rem;
      line-height: 1.6;
    }

    /* Why Section */
    .why-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
    .why-list {
      list-style: none;
      padding: 0;
      margin-top: 1.5rem;
    }
    .why-list li {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.6rem 0;
      color: var(--neutral-700);
      font-weight: 500;
    }
    .why-list li svg { color: var(--success); flex-shrink: 0; }
    .why-cta-card {
      background: white;
      border: 1px solid var(--neutral-200);
      border-radius: var(--radius-lg);
      padding: 2.5rem;
      text-align: center;
      position: relative; overflow: hidden;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .why-cta-card::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(2, 132, 199, 0.03) 0%, rgba(7, 89, 133, 0.06) 100%);
      opacity: 0; transition: opacity 0.4s;
    }
    .why-cta-card:hover::before { opacity: 1; }
    .why-cta-card:hover { box-shadow: 0 12px 32px rgba(2, 132, 199, 0.1), 0 4px 8px rgba(0,0,0,0.04); border-color: var(--primary-200); transform: translateY(-3px); }
    .why-cta-card .btn-secondary {
      display: inline-flex;
    }

    @media (max-width: 768px) {
      .legal-hero { padding: 3.5rem 1rem 3rem; }
      .featured-grid { grid-template-columns: 1fr; gap: 2rem; }
      .featured-photo { max-width: 400px; margin: 0 auto; }
      .team-grid { grid-template-columns: 1fr; max-width: 400px; margin-left: auto; margin-right: auto; }
      .team-grid--2col { grid-template-columns: 1fr; }
      .why-grid { grid-template-columns: 1fr; gap: 2rem; }
    }
    @media (max-width: 480px) {
      .featured-highlights { flex-direction: column; }
    }

    [data-animate] {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    [data-animate].visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</Layout>