---
import Layout from '../layouts/Layout.astro';

const title = 'Contact Us | Dr. Alan S. Lee, DDS';
const description = 'Contact Dr. Alan S. Lee, DDS in Manteca, CA. Call (209) 239-2990, visit us at 715 N Main St, or send us a message online. We are here to help.';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "Dentist",
  name: "Dr. Alan S. Lee, DDS",
  url: "https://dralanlee.com/contact/",
  telephone: "+1-209-239-2990",
  email: "info@dralanlee.com",
  address: {
    "@type": "PostalAddress",
    streetAddress: "715 N Main St",
    addressLocality: "Manteca",
    addressRegion: "CA",
    postalCode: "95336",
    addressCountry: "US"
  },
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday"], opens: "08:00", closes: "16:30" }
  ],
  contactPoint: {
    "@type": "ContactPoint",
    telephone: "+1-209-239-2990",
    contactType: "customer service",
    availableLanguage: "English"
  }
};
---

<Layout title={title} description={description} schema={localBusinessSchema}>
  <!-- Hero -->
  <section class="legal-hero" data-animate>
    <div class="container-wide">
      <div class="section-label">Get in Touch</div>
      <h1 class="section-title">Contact Our Office</h1>
      <p class="legal-hero-subtitle">We are here to answer your questions, schedule appointments, and help with anything you need.</p>
    </div>
  </section>

  <!-- Contact Grid -->
  <section class="section-pad">
    <div class="contact-grid">
      <!-- Contact Form: JotForm Embed -->
      <div class="form-column" data-animate>
        <!-- Form Tabs -->
        <div class="form-tabs">
          <button class="form-tab active" data-tab="appointment" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            Request Appointment
          </button>
          <button class="form-tab" data-tab="message" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            Send a Message
          </button>
        </div>

        <!-- Appointment Form -->
        <div class="form-panel active" id="panel-appointment">
          <div class="form-header">
            <h2>Request an Appointment</h2>
            <p>Schedule your visit — we’ll confirm your appointment within one business day.</p>
          </div>
          <div class="jotform-embed" id="appointment-form-container">
            <script type="text/javascript" src="https://form.jotform.com/jsform/260202986387060" async></script>
          </div>
        </div>

        <!-- Message Form -->
        <div class="form-panel" id="panel-message">
          <div class="form-header">
            <h2>Send Us a Message</h2>
            <p>Fill out the form below and we will get back to you within one business day.</p>
          </div>
          <div class="jotform-embed" id="contact-form-container">
            <script type="text/javascript" src="https://form.jotform.com/jsform/250783246754060" async></script>
          </div>
        </div>
          <noscript>
            <p>Your browser does not support JavaScript. Please <a href="https://form.jotform.com/250783246754060" target="_blank" rel="noopener noreferrer">fill out the contact form</a> directly.</p>
          </noscript>
        </div>

        <div class="form-disclaimer">
          <p><small>By submitting this form, you consent to being contacted regarding your inquiry. Your information is handled in accordance with our <a href="/hipaa-privacy/">HIPAA Notice of Privacy Practices</a>.</small></p>
          <p><small style="font-size: 0.72rem; color: rgba(100,116,139,0.8);">\u2699\uFE0F <strong>Notice at Collection (CCPA):</strong> We collect your name, email, phone number, and message to respond to your inquiry. We do not sell your personal information. See our <a href="/privacy-policy/" style="color: rgba(100,116,139,0.9);">Privacy Policy</a> for your California privacy rights.</small></p>
        </div>
      </div>

      <!-- Info Column -->
      <div class="info-column" data-animate>
        <div class="info-card">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <h3>Call Us Directly</h3>
          <a href="tel:+12092392990" class="phone-large">(209) 239-2990</a>
          <p>For urgent dental needs, please call us directly.</p>
        </div>

        <div class="info-card">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <h3>Office Hours</h3>
          <div class="hours-grid">
            <div class="hours-row"><span>Monday</span><span>8:00 AM – 4:30 PM</span></div>
            <div class="hours-row"><span>Tuesday</span><span>8:00 AM – 4:30 PM</span></div>
            <div class="hours-row"><span>Wednesday</span><span>8:00 AM – 4:30 PM</span></div>
            <div class="hours-row"><span>Thursday</span><span>8:00 AM – 4:30 PM</span></div>
            <div class="hours-row"><span>Friday</span><span>Closed</span></div>
            <div class="hours-row"><span>Saturday</span><span>Closed</span></div>
            <div class="hours-row"><span>Sunday</span><span>Closed</span></div>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <h3>Our Location</h3>
          <p>715 N Main St<br />Manteca, CA 95336</p>
          <a href="https://maps.google.com/?q=715+N+Main+St+Manteca+CA+95336" target="_blank" rel="noopener noreferrer" class="btn-secondary btn-sm">Get Directions →</a>
        </div>

        <div class="info-card hipaa-card">
          <div class="info-icon shield">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
          </div>
          <h3>HIPAA Secure</h3>
          <p>Your information is encrypted and protected under HIPAA regulations. <a href="/hipaa-privacy/">Privacy Notice</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="section-pad" style="padding-top: 0;">
    <div class="container-narrow" data-animate>
      <div class="map-embed">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3135.5!2d-121.2167!3d37.7975!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x809046e4e4e4e4e%3A0xe4e4e4e4e4e4e4e!2s715+N+Main+St%2C+Manteca%2C+CA+95336!5e0!3m2!1sen!2sus!4v1234567890" width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Dr. Alan S. Lee office location on Google Maps"></iframe>
      </div>
    </div>
  </section>

  <style>
    .legal-hero {
      background: linear-gradient(135deg, var(--primary-950) 0%, var(--primary-800) 100%);
      color: white; padding: 5rem 1.5rem 4rem; text-align: center;
    }
    .legal-hero .section-label { color: var(--accent-400); justify-content: center; }
    .legal-hero .section-label::before { background: var(--accent-400); }
    .legal-hero .section-title { color: white; margin-bottom: 1rem; }
    .legal-hero-subtitle { color: rgba(255,255,255,0.85); font-size: 1.1rem; max-width: 680px; margin: 0 auto; line-height: 1.7; font-weight: 300; }

    .contact-grid {
      display: grid; grid-template-columns: 1fr 380px; gap: 3rem;
      max-width: 1280px; margin: 0 auto; padding: 0 1.5rem;
    }
    .info-column { display: flex; flex-direction: column; gap: 1.25rem; }
    .info-card {
      background: white; border: 1px solid var(--neutral-200); border-radius: var(--radius-md);
      padding: 1.5rem; transition: all var(--transition-base);
    }
    .info-card:hover { box-shadow: var(--shadow-md); border-color: var(--primary-200); }
    .info-icon {
      width: 44px; height: 44px; border-radius: var(--radius-md);
      background: var(--primary-50); color: var(--primary-600);
      display: flex; align-items: center; justify-content: center; margin-bottom: 0.75rem;
    }
    .info-icon.shield { background: #ecfdf5; color: #059669; }
    .info-card h3 { font-family: var(--font-body); font-weight: 600; font-size: 1rem; color: var(--neutral-900); margin-bottom: 0.5rem; }
    .info-card p { color: var(--neutral-600); font-size: 0.9rem; line-height: 1.6; }
    .phone-large { font-size: 1.5rem; font-weight: 700; color: var(--primary-700); display: block; margin-bottom: 0.5rem; }
    .phone-large:hover { color: var(--primary-500); }
    .hipaa-card { background: linear-gradient(135deg, #ecfdf5, #d1fae5); border-color: #6ee7b7; }
    .hours-grid { width: 100%; }
    .hours-row { display: flex; justify-content: space-between; padding: 0.35rem 0; font-size: 0.88rem; border-bottom: 1px solid var(--neutral-100); }
    .hours-row:last-child { border-bottom: none; }
    .hours-row span:first-child { color: var(--neutral-700); font-weight: 500; }
    .hours-row span:last-child { color: var(--neutral-600); }
    .btn-sm { padding: 0.55rem 1.25rem; font-size: 0.85rem; }

    .form-tabs { display: flex; gap: 0; margin-bottom: 1.5rem; border-radius: var(--radius-md); overflow: hidden; border: 1px solid var(--neutral-200); }
    .form-tab {
      flex: 1; display: flex; align-items: center; justify-content: center; gap: 0.5rem;
      padding: 0.85rem 1rem; font-size: 0.92rem; font-weight: 600;
      background: var(--neutral-50); color: var(--neutral-500); border: none; cursor: pointer;
      transition: all var(--transition-fast); font-family: var(--font-body);
    }
    .form-tab:hover { background: var(--neutral-100); color: var(--neutral-700); }
    .form-tab.active { background: var(--primary-700); color: white; }
    .form-tab svg { flex-shrink: 0; }
    .form-panel { display: none; }
    .form-panel.active { display: block; }
    .form-header { margin-bottom: 1.5rem; }
    .form-header h2 { font-family: var(--font-display); font-size: 1.5rem; color: var(--neutral-900); margin-bottom: 0.5rem; }
    .form-header p { color: var(--neutral-500); line-height: 1.6; }
    .jotform-embed {
      min-height: 550px; background: var(--neutral-50);
      border: 1px solid var(--neutral-200); border-radius: var(--radius-md); overflow: hidden;
    }
    .form-disclaimer { margin-top: 1rem; text-align: center; }
    .form-disclaimer small { color: var(--neutral-400); font-size: 0.82rem; }
    .form-disclaimer a { color: var(--primary-600); }
    .map-embed { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-lg); border: 1px solid var(--neutral-200); }
    .map-embed iframe { display: block; }

    @media (max-width: 1024px) {
      .contact-grid { grid-template-columns: 1fr; }
      .info-column { order: 2; }
      .form-column { order: 1; }
    }
    @media (max-width: 768px) {
      .legal-hero { padding: 3.5rem 1rem 3rem; }
      .contact-grid { padding: 0 1rem; }
      .jotform-embed { min-height: 450px; }
      .form-tab { font-size: 0.82rem; padding: 0.7rem 0.5rem; }
    }
  </style>

  <script>
    // Tab switching for contact forms
    document.querySelectorAll('.form-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        // Update tabs
        document.querySelectorAll('.form-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        // Update panels
        document.querySelectorAll('.form-panel').forEach(p => p.classList.remove('active'));
        document.getElementById('panel-' + target).classList.add('active');
      });
    });
  </script>
</Layout>