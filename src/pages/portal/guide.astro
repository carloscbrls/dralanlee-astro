---
import Layout from '../../layouts/Layout.astro';

const title = 'CC3PO Client Guide | Dr. Alan S. Lee, DDS';
const description = 'Your complete guide to the CC3PO portal, website features, and support process.';
const canonicalUrl = 'https://dralanlee.com/portal/guide/';
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>
  <section class="legal-hero" data-animate>
    <div class="container-wide">
      <div class="section-label">Client Guide</div>
      <h1 class="section-title">Your Website Guide</h1>
      <p class="legal-hero-subtitle">Everything you need to know about your website, portal, and how to get help — in plain language.</p>
    </div>
  </section>
  <!-- Trust Bar -->
  <section class="trust-bar" data-animate>
    <div class="container-narrow">
      <div class="trust-inner">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
        <span>We built this guide to help you get the most from your website. If anything is unclear, contact us at (209) 239-2990.</span>
      </div>
    </div>
  </section>



  <!-- Table of Contents -->
  <section class="section-pad" data-animate>
    <div class="container-narrow">
      <div class="toc-card">
        <h2>In This Guide</h2>
        <div class="toc-grid">
          <a href="#what-we-built" class="toc-item">
            <span class="toc-num">1</span>
            <span>What We Built For You</span>
          </a>
          <a href="#how-to-request" class="toc-item">
            <span class="toc-num">2</span>
            <span>How to Request Changes</span>
          </a>
          <a href="#portal" class="toc-item">
            <span class="toc-num">3</span>
            <span>Your Client Portal</span>
          </a>
          <a href="#patient-forms" class="toc-item">
            <span class="toc-num">4</span>
            <span>Patient Forms — How They Work</span>
          </a>
          <a href="#features" class="toc-item">
            <span class="toc-num">5</span>
            <span>Website Features Explained</span>
          </a>
          <a href="#hipaa" class="toc-item">
            <span class="toc-num">6</span>
            <span>HIPAA & Compliance — What It Means</span>
          </a>
          <a href="#faqs" class="toc-item">
            <span class="toc-num">7</span>
            <span>Frequently Asked Questions</span>
          </a>
          <a href="#support" class="toc-item">
            <span class="toc-num">8</span>
            <span>How to Get Help</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 1: What We Built -->
  <section class="section-pad alt-bg" id="what-we-built" data-animate>
    <div class="container-narrow">
      <div class="section-label">Overview</div>
      <h2 class="section-heading">What We Built For You</h2>
      <p class="section-description">Your website is more than just a homepage. Here's everything that's included and how it all works together.</p>

      <div class="overview-grid">
        <div class="overview-card">
          <div class="overview-icon website">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          </div>
          <h3>Your Website</h3>
          <p>A modern, fast website at <strong>dralanlee.com</strong> that patients can find on Google, loads in under 2 seconds, and works perfectly on phones.</p>
          <span class="overview-tag">dralanlee.com</span>
        </div>

        <div class="overview-card">
          <div class="overview-icon forms">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><path d="m9 15 2 2 4-4"></path></svg>
          </div>
          <h3>Patient Forms</h3>
          <p>7 HIPAA-compliant forms that patients fill out online. They open right on your website — no redirects to other sites. All data is encrypted and sent directly to your office.</p>
          <span class="overview-tag">dralanlee.com/forms-library/</span>
        </div>

        <div class="overview-card">
          <div class="overview-icon portal">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          </div>
          <h3>Client Portal</h3>
          <p>A private dashboard where you can see your compliance score, access legal documents, view form submissions, and request changes. Password-protected — only authorized people can access it.</p>
          <span class="overview-tag">dralanlee.com/portal/</span>
        </div>

        <div class="overview-card">
          <div class="overview-icon shield">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
          </div>
          <h3>HIPAA & Compliance</h3>
          <p>Your website meets HIPAA requirements for handling patient health information. We handle the technical compliance so you don't have to worry about it. Your compliance score: <strong>92/100 (A-)</strong>.</p>
          <span class="overview-tag">Audited May 15, 2026</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: How to Request Changes -->
  <section class="section-pad" id="how-to-request" data-animate>
    <div class="container-narrow">
      <div class="section-label">Getting Help</div>
      <h2 class="section-heading">How to Request Changes</h2>
      <p class="section-description">Need something changed on your website? Here's exactly how to do it, step by step.</p>

      <div class="steps-grid">
        <div class="step-card">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>Choose How to Reach Us</h3>
            <div class="contact-options">
              <div class="contact-opt">
                <div class="contact-opt-icon phone">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                </div>
                <div>
                  <strong>Call (Urgent)</strong>
                  <span>(209) 423-6633</span>
                  <em>Website down? Security issue? Call anytime.</em>
                </div>
              </div>
              <div class="contact-opt">
                <div class="contact-opt-icon text">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                </div>
                <div>
                  <strong>Text (Quick Changes)</strong>
                  <span>(209) 232-1265</span>
                  <em>Update hours, change a photo, fix a typo. We respond in 2 hours.</em>
                </div>
              </div>
              <div class="contact-opt">
                <div class="contact-opt-icon email">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                </div>
                <div>
                  <strong>Email (Detailed)</strong>
                  <span>legal@cc3po.com</span>
                  <em>Longer requests, attachments, or compliance questions.</em>
                </div>
              </div>
              <div class="contact-opt">
                <div class="contact-opt-icon portal-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                </div>
                <div>
                  <strong>Portal (Form)</strong>
                  <span>dralanlee.com/portal/support/</span>
                  <em>Submit a structured request with categories and priority.</em>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="step-card">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>Tell Us What You Need</h3>
            <p>Be as specific or as general as you want. Here are examples of good requests:</p>
            <div class="example-grid">
              <div class="example good">
                <div class="example-label">✅ Great Request</div>
                <p>"Please update our office hours to Monday–Thursday 9:00 AM – 5:00 PM, closed Fridays"</p>
              </div>
              <div class="example good">
                <div class="example-label">✅ Great Request</div>
                <p>"Add Dr. Sarah Chen to the Our Team page — she's a new hygienist starting June 1st"</p>
              </div>
              <div class="example good">
                <div class="example-label">✅ Great Request</div>
                <p>"There's a typo on the Services page — 'cosmetic' is misspelled"</p>
              </div>
              <div class="example ok">
                <div class="example-label">👍 Also Fine</div>
                <p>"Something looks weird on the website" — We'll ask follow-up questions</p>
              </div>
              <div class="example ok">
                <div class="example-label">👍 Also Fine</div>
                <p>"I'm not sure what I need, can you call me?" — Yes, absolutely</p>
              </div>
            </div>
            <p class="step-note">💡 <strong>You don't need to know technical terms.</strong> Just describe what you want in your own words. We'll figure out the rest.</p>
          </div>
        </div>

        <div class="step-card">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>We Handle It</h3>
            <p>Your request goes through this process:</p>
            <div class="process-flow">
              <div class="process-step">
                <div class="process-num">A</div>
                <div><strong>We review your request</strong><br>We read it, make sure we understand, and confirm back to you.</div>
              </div>
              <div class="process-arrow">→</div>
              <div class="process-step">
                <div class="process-num">B</div>
                <div><strong>Carlos approves</strong><br>Before any changes go live, Carlos reviews and approves. Nothing changes without his sign-off.</div>
              </div>
              <div class="process-arrow">→</div>
              <div class="process-step">
                <div class="process-num">C</div>
                <div><strong>We make the change</strong><br>The technical team implements the change on your website.</div>
              </div>
              <div class="process-arrow">→</div>
              <div class="process-step">
                <div class="process-num">D</div>
                <div><strong>You confirm it's done</strong><br>We send you a link to review the change. You say it looks good, or we adjust.</div>
              </div>
            </div>
            <p class="step-note">🔒 <strong>Nothing goes live without approval.</strong> If you request a change, we always confirm before publishing.</p>
          </div>
        </div>

        <div class="step-card">
          <div class="step-number">4</div>
          <div class="step-content">
            <h3>Typical Response Times</h3>
            <div class="response-table">
              <div class="response-row header">
                <span>Priority</span>
                <span>What It Means</span>
                <span>Response Time</span>
              </div>
              <div class="response-row critical">
                <span class="badge critical">Critical</span>
                <span>Website is down, security issue, patient data concern</span>
                <span>Within 1 hour</span>
              </div>
              <div class="response-row high">
                <span class="badge high">High</span>
                <span>Broken form, incorrect info, can't take appointments</span>
                <span>Within 4 hours</span>
              </div>
              <div class="response-row medium">
                <span class="badge medium">Medium</span>
                <span>Update hours, add staff member, change a photo</span>
                <span>Within 24 hours</span>
              </div>
              <div class="response-row low">
                <span class="badge low">Low</span>
                <span>Cosmetic tweak, new feature idea, general question</span>
                <span>Within 48 hours</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Portal -->
  <section class="section-pad alt-bg" id="portal" data-animate>
    <div class="container-narrow">
      <div class="section-label">Private Access</div>
      <h2 class="section-heading">Your Client Portal</h2>
      <p class="section-description">A private, password-protected area just for your practice. Here's what's inside and how to access it.</p>

      <div class="feature-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3>Compliance Score</h3>
          <p>See your HIPAA compliance score at a glance — currently <strong>92/100 (A-)</strong>. We audit regularly and update it.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
          </div>
          <h3>Compliance Documents</h3>
          <p>All your legal pages in one place: HIPAA Notice, Privacy Policy, No Surprises Act, Accessibility, Terms of Service.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
          </div>
          <h3>JotForm Inbox</h3>
          <p>Log in to JotForm to view all patient form submissions. Encrypted and HIPAA-compliant. Your username and password were set up when we created your forms.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
          </div>
          <h3>Support Request</h3>
          <p>Submit website change requests, ask questions, or report issues directly through the portal.</p>
        </div>
      </div>

      <div class="how-to-access">
        <h3>How to Access the Portal</h3>
        <ol class="access-steps">
          <li>Go to <strong>dralanlee.com/portal/</strong></li>
          <li>Enter your email address (<strong>info@dralanlee.com</strong>)</li>
          <li>Check your email for a one-time verification code</li>
          <li>Enter the code — you're in!</li>
        </ol>
        <p class="access-note">💡 <strong>No password to remember.</strong> You just need access to your email. Each time you visit, we send a fresh code. This is the same security system used by banks and healthcare portals.</p>
      </div>
    </div>
  </section>

  <!-- Section 4: Patient Forms -->
  <section class="section-pad" id="patient-forms" data-animate>
    <div class="container-narrow">
      <div class="section-label">Patient Experience</div>
      <h2 class="section-heading">Patient Forms — How They Work</h2>
      <p class="section-description">Your patients fill out forms on your website. Here's what happens with that data and how to view submissions.</p>

      <div class="flow-diagram">
        <div class="flow-step">
          <div class="flow-num">1</div>
          <h4>Patient Visits Your Website</h4>
          <p>They go to <strong>dralanlee.com/forms-library/</strong> and click the form they need.</p>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step">
          <div class="flow-num">2</div>
          <h4>Form Opens In-Page</h4>
          <p>The form opens right on your website — no redirect to JotForm. Patient never leaves dralanlee.com.</p>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step">
          <div class="flow-num">3</div>
          <h4>Data Is Encrypted</h4>
          <p>All data is encrypted (HIPAA-compliant) and sent directly to JotForm's secure servers. It never passes through our servers.</p>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step">
          <div class="flow-num">4</div>
          <h4>You View Submissions</h4>
          <p>Log into <strong>hipaa.jotform.com</strong> with your credentials to see all submissions. You can also set up email notifications.</p>
        </div>
      </div>

      <div class="forms-list">
        <h3>Your Active Forms</h3>
        <table class="forms-table">
          <thead>
            <tr><th>Form Name</th><th>Purpose</th><th>Status</th></tr>
          </thead>
          <tbody>
            <tr><td>New Patient Registration</td><td>Personal info, contact, insurance, demographics</td><td><span class="status-active">✅ Active</span></td></tr>
            <tr><td>Medical & Dental History</td><td>Medications, allergies, past treatments</td><td><span class="status-active">✅ Active</span></td></tr>
            <tr><td>HIPAA Privacy Consent & Intake</td><td>HIPAA acknowledgment, medical history, consent</td><td><span class="status-active">✅ Active</span></td></tr>
            <tr><td>Insurance Verification</td><td>Dental insurance details</td><td><span class="status-active">✅ Active</span></td></tr>
            <tr><td>Consent for Treatment</td><td>Authorize dental exams and treatment</td><td><span class="status-active">✅ Active</span></td></tr>
            <tr><td>Records Release Authorization</td><td>Authorize release of dental records</td><td><span class="status-active">✅ Active</span></td></tr>
            <tr><td>Financial Responsibility</td><td>Acknowledge financial responsibility</td><td><span class="status-active">✅ Active</span></td></tr>
          </tbody>
        </table>
        <p class="forms-note">🔒 <strong>All forms are HIPAA-compliant.</strong> JotForm's HIPAA plan includes a Business Associate Agreement (BAA), encryption at rest, and access controls. Patient data is never stored on our servers.</p>
      </div>
    </div>
  </section>

  <!-- Section 5: Website Features -->
  <section class="section-pad alt-bg" id="features" data-animate>
    <div class="container-narrow">
      <div class="section-label">Features</div>
      <h2 class="section-heading">Website Features Explained</h2>
      <p class="section-description">Here's what each part of your website does and why it matters.</p>

      <div class="features-list-grid">
        <div class="feature-explained">
          <h4>🔒 HIPAA Compliance Badge</h4>
          <p>The "HIPAA Compliant" and "HIPAA Secure" badges in your website header tell patients their data is protected. These are backed by real compliance — your HIPAA Notice of Privacy Practices, Patient Privacy Rights page, and encryption on all forms.</p>
          <span class="feature-where">Visible on every page, top right</span>
        </div>
        <div class="feature-explained">
          <h4>📋 Patient Forms Library</h4>
          <p>7 HIPAA-compliant forms that patients fill out online before their visit. This saves your staff time at check-in and reduces paper handling. Forms open directly on your website — no redirecting patients to external sites.</p>
          <span class="feature-where">dralanlee.com/forms-library/</span>
        </div>
        <div class="feature-explained">
          <h4>📅 Online Appointment Scheduling</h4>
          <p>Patients can request appointments online through a HIPAA-compliant JotForm. You'll receive an email notification for each request and can confirm by phone.</p>
          <span class="feature-where">dralanlee.com/schedule-appointment/</span>
        </div>
        <div class="feature-explained">
          <h4>💳 Pay Online</h4>
          <p>Patients can make payments through ConvergePay, a secure hosted payment page. No credit card data ever touches your website — it's all processed on ConvergePay's secure servers.</p>
          <span class="feature-where">dralanlee.com/pay/</span>
        </div>
        <div class="feature-explained">
          <h4>📄 Legal & Compliance Pages</h4>
          <p>Your website includes 6 dedicated compliance pages: HIPAA Notice, Patient Privacy, No Surprises Act, Privacy Policy, Terms of Service, and Accessibility Statement. These protect your practice and are required by law.</p>
          <span class="feature-where">Linked in the footer of every page</span>
        </div>
        <div class="feature-explained">
          <h4>🍪 Cookie Consent Banner</h4>
          <p>By law (CCPA/CPRA for California practices), your website must ask visitors for consent before tracking them. The cookie banner appears once and lets visitors choose what data they share. We use privacy-first analytics (Plausible) that don't track personal data.</p>
          <span class="feature-where">Appears on first visit, bottom of screen</span>
        </div>
        <div class="feature-explained">
          <h4>♿ Accessibility</h4>
          <p>Your website is built to WCAG 2.1 AA standards — keyboard navigation, screen reader support, proper color contrast, and clear labels. This protects your practice from ADA lawsuits and makes your site usable for all patients.</p>
          <span class="feature-where">dralanlee.com/accessibility/</span>
        </div>
        <div class="feature-explained">
          <h4>📊 Privacy-First Analytics</h4>
          <p>We use Plausible Analytics instead of Google Analytics. Plausible is cookie-free, doesn't track personal data, and is fully HIPAA-compliant. It shows us how many people visit your site and which pages they view — nothing more.</p>
          <span class="feature-where">Internal — visible in client portal</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 6: HIPAA -->
  <section class="section-pad" id="hipaa" data-animate>
    <div class="container-narrow">
      <div class="section-label">Compliance</div>
      <h2 class="section-heading">HIPAA & Compliance — What It Means For You</h2>
      <p class="section-description">You don't need to become a HIPAA expert. Here's what matters for your practice.</p>

      <div class="hipaa-grid">
        <div class="hipaa-card">
          <div class="hipaa-icon green">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          </div>
          <h4>What We Handle</h4>
          <ul>
            <li>Website encryption (SSL/TLS)</li>
            <li>Security headers and firewalls</li>
