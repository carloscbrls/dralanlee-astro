---
import Layout from '../layouts/Layout.astro';

const title = 'About Dr. Lee | Dr. Alan S. Lee, DDS - Manteca Dentist';
const description = 'Learn about Dr. Alan S. Lee, DDS - trusted Manteca dentist for over 30 years. Gentle, patient-focused dental care. Call (209) 239-2990.';

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About Dr. Alan S. Lee, DDS",
  "description": "Dr. Alan S. Lee has been providing compassionate dental care in Manteca, CA for over 30 years.",
  "url": "https://dralanlee.com/about/",
  "mainEntity": {
    "@type": "Dentist",
    "name": "Dr. Alan S. Lee, DDS",
    "description": "General & Cosmetic Dentistry in Manteca, CA - trusted for over 30 years.",
    "image": "https://dralanlee.com/images/dr-lee-portrait-2026-new.jpg"
  }
};
---

<Layout title={title} description={description} schema={aboutSchema}>
  <!-- Hero -->
  <section class="legal-hero" data-animate>
    <div class="container-wide">
      <div class="section-label">About Dr. Lee</div>
      <h1 class="section-title">Serving Manteca Since 1989</h1>
      <p class="legal-hero-subtitle">Over 30 years of gentle, patient-centered dentistry built on trust, compassion, and a genuine love for the community.</p>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="trust-bar" data-animate>
    <div class="container-narrow">
      <div class="trust-inner">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
        <span>Serving the Manteca community with trust and compassion for over 30 years. Your comfort and care always come first.</span>
      </div>
    </div>
  </section>

  <!-- Dr. Lee Story -->
  <section class="about-story section-pad" data-animate>
    <div class="container-wide about-story-grid">
      <div class="about-photo-wrap" data-animate>
        <img
          src="/images/dr-lee-portrait-2026-new.jpg"
          alt="Dr. Alan S. Lee, DDS - providing dental care in Manteca for over 30 years"
          class="about-photo"
          width="960"
          height="1280"
          loading="eager"
        />
        <div class="photo-badge">
          <span class="badge-number">30+</span>
          <span class="badge-text">Years Serving<br/>Manteca</span>
        </div>
      </div>
      <div class="about-text" data-animate>
        <h2 class="section-title" style="font-size: 2rem;">Meet Dr. Alan S. Lee</h2>
        <p>Dr. Alan S. Lee has been a trusted part of the Manteca community for over three decades. After earning his Doctor of Dental Surgery degree, he chose Manteca as his home - and the community has been his family ever since.</p>
        <p>Dr. Lee believes that great dentistry starts with trust. His approach combines advanced clinical techniques with a gentle, personalized touch that puts even the most anxious patients at ease. Whether it's a routine checkup or a complex restorative case, Dr. Lee takes the time to listen, explain, and care for every patient like family.</p>
        <p>Throughout his career, Dr. Lee has remained committed to continuing education, staying current with the latest advances in dental science, technology, and patient comfort. His practice is a reflection of his values: honest, thorough, and always focused on what's best for the patient.</p>

        <div class="about-highlights">
          <div class="highlight-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            <span>Gentle, patient-first approach</span>
          </div>
          <div class="highlight-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span>Patient-focused care for adults</span>
          </div>
          <div class="highlight-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
            <span>30+ years of community trust</span>
          </div>
          <div class="highlight-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.37 7.37l-6.83 6.83a2 2 0 0 1-2.83-2.83l6.83-6.83a6 6 0 0 1 7.37-7.37z"/></svg>
            <span>Modern techniques &amp; technology</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="values-section section-pad" data-animate style="background: var(--neutral-50);">
    <div class="container-wide">
      <div class="section-label">Our Philosophy</div>
      <h2 class="section-title">What We Believe</h2>
      <div class="values-grid">
        <div class="value-card" data-animate>
          <div class="value-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3>Compassion First</h3>
          <p>We treat every patient with kindness and empathy. Your comfort is never an afterthought - it's the foundation of everything we do.</p>
        </div>
        <div class="value-card" data-animate>
          <div class="value-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Trust & Transparency</h3>
          <p>We explain every treatment option clearly and honestly. No surprises, no unnecessary procedures - just straightforward care you can count on.</p>
        </div>
        <div class="value-card" data-animate>
          <div class="value-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          </div>
          <h3>Gentle Experience</h3>
          <p>Dental visits shouldn't be stressful. From our welcoming front office to Dr. Lee's gentle technique, we make every visit as comfortable as possible.</p>
        </div>
        <div class="value-card" data-animate>
          <div class="value-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3>Prevention Focus</h3>
          <p>The best treatment is preventing problems before they start. We emphasize proactive care and patient education to keep you healthy long-term.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-pad cta-section" data-animate>
    <div class="container-narrow" style="text-align: center;">
      <div class="section-label" style="justify-content: center;">Experience the Difference</div>
      <h2 class="section-title">Join the Dr. Lee Family</h2>
      <p class="section-subtitle" style="margin: 0 auto 2rem;">Join the thousands of Manteca families who trust Dr. Lee with their dental care. We’re always accepting new patients.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/schedule-appointment/" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Schedule Your Visit
        </a>
        <a href="tel:+12092392990" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call (209) 239-2990
        </a>
      </div>
    </div>
  </section>

  <style>

    /* Hero & Trust Bar */
    .legal-hero { background: linear-gradient(135deg, var(--primary-950) 0%, var(--primary-800) 100%); color: white; padding: 5rem 1.5rem 4rem; text-align: center; }
    .legal-hero .section-label { color: var(--accent-400); justify-content: center; }
    .legal-hero .section-label::before { background: var(--accent-400); }
    .legal-hero .section-title { color: white; margin-bottom: 1rem; }
    .legal-hero-subtitle { color: rgba(255,255,255,0.85); font-size: 1.1rem; max-width: 600px; margin: 0 auto; line-height: 1.7; font-weight: 300; }
    .trust-bar { background: linear-gradient(135deg, #059669 0%, #047857 100%); padding: 1rem 1.5rem; position: relative; overflow: hidden; }
    .trust-bar::before { content: ''; position: absolute; top: 0; right: 0; width: 200px; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06)); }
    .trust-inner { max-width: 800px; margin: 0 auto; display: flex; align-items: center; gap: 0.75rem; color: white; font-size: 0.9rem; font-weight: 500; position: relative; }
    .trust-inner svg { flex-shrink: 0; }
    .about-story-grid {
      display: grid;
      grid-template-columns: 1fr 1.3fr;
      gap: 4rem;
      align-items: center;
    }
    .about-photo-wrap {
      position: relative;
    }
    .about-photo {
      width: 100%;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-xl);
      aspect-ratio: 1 / 1;
      object-fit: cover;
    }
    .photo-badge {
      position: absolute;
      bottom: -1rem;
      right: -1rem;
      background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-800) 100%);
      color: white;
      padding: 1.25rem 1.5rem;
      border-radius: var(--radius-md);
      box-shadow: 0 8px 24px rgba(2, 132, 199, 0.35);
      text-align: center;
    }
    .badge-number {
      display: block;
      font-family: var(--font-display);
      font-size: 2rem;
      line-height: 1;
      font-weight: 700;
    }
    .badge-text {
      font-size: 0.75rem;
      font-weight: 500;
      line-height: 1.3;
      opacity: 0.9;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .about-text p {
      color: var(--neutral-600);
      font-size: 1rem;
      line-height: 1.8;
      margin-bottom: 1rem;
    }
    .about-text p:last-of-type { margin-bottom: 1.5rem; }

    .about-highlights {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }
    .highlight-item {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.65rem 1rem;
      background: linear-gradient(135deg, rgba(2, 132, 199, 0.06) 0%, rgba(7, 89, 133, 0.1) 100%);
      border: 1px solid rgba(2, 132, 199, 0.12);
      border-radius: var(--radius-sm);
      font-size: 0.88rem;
      font-weight: 500;
      color: var(--primary-800);
      transition: all 0.3s ease;
    }
    .highlight-item:hover {
      background: linear-gradient(135deg, rgba(2, 132, 199, 0.1) 0%, rgba(7, 89, 133, 0.16) 100%);
      border-color: rgba(2, 132, 199, 0.25);
      transform: translateY(-1px);
    }
    .highlight-item svg { color: var(--primary-500); flex-shrink: 0; }

    /* Values */
    .values-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .value-card {
      background: white;
      padding: 2rem;
      border-radius: var(--radius-lg);
      border: 1px solid var(--neutral-200);
      text-align: center;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }
    .value-card::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(2, 132, 199, 0.03) 0%, rgba(7, 89, 133, 0.06) 100%);
      opacity: 0; transition: opacity 0.4s;
    }
    .value-card:hover::before { opacity: 1; }
    .value-card:hover {
      box-shadow: 0 16px 40px rgba(2, 132, 199, 0.1), 0 4px 10px rgba(0,0,0,0.04);
      transform: translateY(-4px);
      border-color: var(--primary-200);
    }
    .value-icon {
      width: 56px; height: 56px;
      display: flex; align-items: center; justify-content: center;
      background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-800) 100%);
      color: white;
      border-radius: var(--radius-md);
      margin: 0 auto 1.25rem;
      box-shadow: 0 4px 14px rgba(2, 132, 199, 0.25);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .value-card:hover .value-icon { transform: scale(1.08); box-shadow: 0 8px 24px rgba(2, 132, 199, 0.35); }
    .value-card h3 {
      font-family: var(--font-display);
      font-size: 1.15rem;
      margin-bottom: 0.75rem;
      color: var(--neutral-900);
      transition: color 0.3s;
    }
    .value-card:hover h3 { color: var(--primary-700); }
    .value-card p {
      color: var(--neutral-500);
      font-size: 0.9rem;
      line-height: 1.6;
    }

    /* CTA */
    @media (max-width: 768px) {
      .about-story-grid { grid-template-columns: 1fr; gap: 2rem; }
      .about-photo { max-width: 400px; margin: 0 auto; }
      .values-grid { grid-template-columns: 1fr 1fr; }
      .about-highlights { grid-template-columns: 1fr; }
      .legal-hero { padding: 3.5rem 1rem 3rem; }
    }
    @media (max-width: 480px) {
      .values-grid { grid-template-columns: 1fr; }
    }

    [data-animate] {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    [data-animate].visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</Layout>